# ARQUIVO: game/episode019.rpy DIALOGOS: 2077


# game/episode019.rpy:52
translate spanish episode019_44a4c3f4:

#   centered "{=chapter_heading}EPISODE 19{/=chapter_heading}"
    centered "{=chapter_heading}EPISODIO 19{/=chapter_heading}"

# game/episode019.rpy:62
translate spanish episode019_a4dc0f57:

#   op "Commander?"
    op "¿Comandante?"

# game/episode019.rpy:63
translate spanish episode019_f33bc2dd:

#   ca "Go away."
    ca "Váyase."

# game/episode019.rpy:64
translate spanish episode019_520077a4:

#   op "Commander Calista Szuzume?"
    op "¿Comandante Calista Szuzume?"

# game/episode019.rpy:66
translate spanish episode019_ad983fe8:

#   ca "Former Commander."
    ca "Ex Comandante."

# game/episode019.rpy:67
translate spanish episode019_277b4c9c:

#   ca "Have you come to gloat?"
    ca "¿Has venido a regodearte?"

# game/episode019.rpy:69
translate spanish episode019_5099a9eb:

#   op "Not at all, Commander."
    op "En absoluto, Comandante."

# game/episode019.rpy:70
translate spanish episode019_320f31a4:

#   ca "As I said, not a Commander anymore."
    ca "Como he dicho, ya no es un Comandante."

# game/episode019.rpy:71
translate spanish episode019_0f8b82be:

#   ca "They took that all away from me."
    ca "Me lo quitaron todo."

# game/episode019.rpy:72
translate spanish episode019_3071cc5e:

#   ca "Over two decades worth of loyal service and then they just discard me."
    ca "Más de dos décadas de servicio leal y luego me descartan."

# game/episode019.rpy:73
translate spanish episode019_794dea2c:

#   ca "But not before making me seemingly kill my own children and ratting them out once they turned out to be very much alive."
    ca "Pero no sin antes hacerme aparentemente matar a mis propios hijos y delatarlos una vez que resultaron estar muy vivos."

# game/episode019.rpy:74
translate spanish episode019_46e09678:

#   ca "And then they took my rank, my retirement money and my apartment."
    ca "Y luego se llevaron mi rango, el dinero de mi jubilación y mi apartamento."

# game/episode019.rpy:75
translate spanish episode019_82c0400b:

#   ca "So fuck off and let me drink."
    ca "Así que vete a la mierda y déjame beber."

# game/episode019.rpy:77
translate spanish episode019_2b9feed5:

#   op "I know all about your plight, Calista."
    op "Lo sé todo sobre tu difícil situación, Calista."

# game/episode019.rpy:78
translate spanish episode019_e137ea03:

#   op "I know the Sovereignty cast you out, as they've done countless times with other people."
    op "Sé que la Soberanía te echó, como ha hecho innumerables veces con otras personas."

# game/episode019.rpy:79
translate spanish episode019_f18e01cd:

#   ca "I don't care, leave me alone."
    ca "No me importa, déjame en paz."

# game/episode019.rpy:81
translate spanish episode019_4cf799f0:

#   op "But you do care, Calista."
    op "Pero te importa, Calista."

# game/episode019.rpy:83
translate spanish episode019_2c97fe41:

#   op "Otherwise you'd have shrugged off the attempted murder on your children and continued to be the diligent soldier you were before."
    op "De lo contrario, te habrías encogido de hombros ante el intento de asesinato de tus hijos y habrías seguido siendo el soldado diligente que eras antes."

# game/episode019.rpy:84
translate spanish episode019_53aad528:

#   op "Instead you're here in the slums, drinking the cheapest liquor on sale."
    op "En vez de eso, estás aquí en los barrios bajos, bebiendo el licor más barato que se vende."

# game/episode019.rpy:86
translate spanish episode019_5ca4b766:

#   ca "Such insight."
    ca "Qué perspicacia."

# game/episode019.rpy:87
translate spanish episode019_21347e9b:

#   ca "What do you want from me?"
    ca "¿Qué quieres de mí?"

# game/episode019.rpy:89
translate spanish episode019_96503f73:

#   ca "Are you one of those undercover bureaucrats tasked with rooting out poor saps voicing mildly dissident opinions so that they can be sent to a re-education camp?"
    ca "¿Es usted uno de esos burócratas encubiertos encargados de descubrir a los pobres infelices que expresan opiniones ligeramente disidentes para enviarlos a un campo de reeducación?"

# game/episode019.rpy:91
translate spanish episode019_6b141d58:

#   op "No, I'm not."
    op "No, no lo estoy."

# game/episode019.rpy:92
translate spanish episode019_cc112a56:

#   op "My parents were sent to one of those camps and I never saw them again."
    op "Mis padres fueron enviados a uno de esos campos y nunca los volví a ver."

# game/episode019.rpy:93
translate spanish episode019_c21c4e4f:

#   op "You’d have to be a monster to send someone away to a place like that."
    op "Hay que ser un monstruo para mandar a alguien a un sitio así."

# game/episode019.rpy:94
translate spanish episode019_27edf1b3:

#   op "So no, I’m not going to rat you out."
    op "Así que no, no voy a delatarte."

# game/episode019.rpy:95
translate spanish episode019_70048591:

#   ca "I'm sorry to hear about your parents."
    ca "Siento lo de tus padres."

# game/episode019.rpy:97
translate spanish episode019_0453485d:

#   op "It was a long time ago."
    op "Fue hace mucho tiempo."

# game/episode019.rpy:98
translate spanish episode019_4faf9557:

#   op "Though I’d be lying if I said that time heals all wounds."
    op "Aunque mentiría si dijera que el tiempo lo cura todo."

# game/episode019.rpy:99
translate spanish episode019_2117458e:

#   op "I know you have little reason to believe me, but I haven't come here to entrap you."
    op "Sé que tienes pocas razones para creerme, pero no he venido aquí para tenderte una trampa."

# game/episode019.rpy:100
translate spanish episode019_50e92e32:

#   op "I've come here to offer you a way to strike back at the Sovereignty."
    op "He venido aquí para ofrecerte una forma de devolverle el golpe a la Soberanía."

# game/episode019.rpy:101
translate spanish episode019_8bf9eb91:

#   op "I represent a group of people who have been disillusioned by the Sovereignty for a long time."
    op "Represento a un grupo de personas desilusionadas por la Soberanía desde hace mucho tiempo."

# game/episode019.rpy:102
translate spanish episode019_31346cec:

#   op "Our group has been attracting new members in secret, and many citizens are sympathetic to our cause."
    op "Nuestro grupo ha atraído a nuevos miembros en secreto, y muchos ciudadanos simpatizan con nuestra causa."

# game/episode019.rpy:104
translate spanish episode019_9026a16e:

#   ca "Hah, let me guess, you're claiming to be part of the Auric Exemplar?"
    ca "Déjame adivinar, ¿dices ser parte del Auric Exemplar?"

# game/episode019.rpy:105
translate spanish episode019_7b39bba9:

#   ca "They're a myth."
    ca "Son un mito."

# game/episode019.rpy:106
translate spanish episode019_9a438866:

#   ca "Or at most a group of dreamy idealists, more interested in philosophizing about resistance, than putting up a fight."
    ca "O, como mucho, un grupo de idealistas soñadores, más interesados en filosofar sobre la resistencia que en presentar batalla."

# game/episode019.rpy:108
translate spanish episode019_39b540bd:

#   op "I'll concede that the people I represent haven't operated out in the open much."
    op "Reconozco que la gente a la que represento no ha operado mucho en campo abierto."

# game/episode019.rpy:109
translate spanish episode019_9e0cd25b:

#   op "But that is about to change."
    op "Pero eso está a punto de cambiar."

# game/episode019.rpy:110
translate spanish episode019_05ca9a23:

#   op "We have been making preparations to strike, but we need help."
    op "Hemos estado haciendo preparativos para atacar, pero necesitamos ayuda."

# game/episode019.rpy:111
translate spanish episode019_fc2f022b:

#   op "Help from people like you, who have been part of the inner workings of the Sovereignty for a long time."
    op "Ayuda de personas como usted, que forman parte del funcionamiento interno de la Soberanía desde hace mucho tiempo."

# game/episode019.rpy:113
translate spanish episode019_3693fb7b:

#   op "I believe we can offer you a way to hit the Sovereignty where it hurts."
    op "Creo que podemos ofrecerle una forma de golpear a la Soberanía donde más le duele."

# game/episode019.rpy:114
translate spanish episode019_beab8ae7:

#   op "Isn't that what you want, Calista, to make them pay for what they did to you?"
    op "¿No es eso lo que quieres, Calista, hacerles pagar por lo que te hicieron?"

# game/episode019.rpy:116
translate spanish episode019_6da671e9:

#   ca "What would you need me for?"
    ca "¿Para qué me necesitas?"

# game/episode019.rpy:118
translate spanish episode019_079b26ff:

#   op "As I said, your knowledge of the workings of Sovereignty leadership would be a tremendous help."
    op "Como ya he dicho, su conocimiento del funcionamiento de la dirección de Soberanía sería de gran ayuda."

# game/episode019.rpy:119
translate spanish episode019_73897f11:

#   op "But so would be your experience as one of the most respected fleet commanders of the Navy."
    op "Pero también lo sería su experiencia como uno de los comandantes de flota más respetados de la Armada."

# game/episode019.rpy:120
translate spanish episode019_5f15bd64:

#   op "All I'm asking is for you to agree to one meeting."
    op "Todo lo que pido es que aceptes una reunión."

# game/episode019.rpy:121
translate spanish episode019_6b0eda8e:

#   op "My superiors will be able to explain more."
    op "Mis superiores podrán explicarme más."

# game/episode019.rpy:122
translate spanish episode019_bc60de9b:

#   op "If you don't like what they tell you, I'll happily escort you back to this place so you continue drinking yourself to death."
    op "Si no te gusta lo que te dicen, te acompañaré encantado de vuelta a este lugar para que sigas bebiendo hasta morir."

# game/episode019.rpy:124
translate spanish episode019_b0ca2893:

#   ca "All charm, aren't you?"
    ca "Todo encanto, ¿verdad?"

# game/episode019.rpy:126
translate spanish episode019_ebbcac0e:

#   op "Just giving you the options."
    op "Sólo te doy las opciones."

# game/episode019.rpy:127
translate spanish episode019_3727a18b:

#   ca "One meeting?"
    ca "¿Una reunión?"

# game/episode019.rpy:129
translate spanish episode019_81d80394:

#   op "That's all we ask."
    op "Es todo lo que pedimos."

# game/episode019.rpy:131
translate spanish episode019_cdaa6553:

#   ca "Do you have a place where I can clean myself up first?"
    ca "¿Tienes un lugar donde pueda asearme primero?"

# game/episode019.rpy:132
translate spanish episode019_adf2cc6b:

#   op "Of course."
    op "Por supuesto."

# game/episode019.rpy:134
translate spanish episode019_3c44f6d6:

#   ca "Lead the way then, Miss Auric Exemplar."
    ca "Guíe el camino entonces, Señorita Auric Exemplar."

# game/episode019.rpy:272
translate spanish ep019_temple_44acd866:

#   "The Sovereignty engineers worked with trained efficiency."
    "Los ingenieros del Sovereignty trabajaron con una eficacia entrenada."

# game/episode019.rpy:274
translate spanish ep019_temple_faa109fb:

#   "The Key was floating inside some sort of force field, but didn't appear to be tied down to the spot where it was hovering."
    "La Llave flotaba dentro de una especie de campo de fuerza, pero no parecía estar atada al lugar donde flotaba."

# game/episode019.rpy:276
translate spanish ep019_temple_561edd7b:

#   "Agust, the Confessor, Kvi and Erylin observed the men working for a time, until Agust got bored and started to bark orders at the crew working on getting the artifact out."
    "Agust, la Confesora, Kvi y Erylin observaron a los hombres trabajar durante un rato, hasta que Agust se aburrió y empezó a ladrar órdenes a la tripulación que trabajaba para sacar el artefacto."

# game/episode019.rpy:277
translate spanish ep019_temple_414f0ca9:

#   "When bossing the workers around lost its appeal as well, the group shuffled out of the temple."
    "Cuando dar órdenes a los trabajadores también perdió su atractivo, el grupo salió del templo."

# game/episode019.rpy:279
translate spanish ep019_temple_6a697b65:

#   "The engines of the armored transport roared back to life, presumably bringing Agust and his friends back to Taagmar."
    "Los motores del transporte blindado volvieron a rugir, llevando presumiblemente a Agust y sus amigos de vuelta a Taagmar."

# game/episode019.rpy:280
translate spanish ep019_temple_4512ee2b:

#   "The foreman breathed a sigh of relief and continued to direct the removal of the Key from its chamber."
    "El capataz respiró aliviado y siguió dirigiendo la extracción de la Llave de su cámara."

# game/episode019.rpy:282
translate spanish ep019_temple_53f31dae:

#   "Several soldiers were directed to wait outside, where a number of trucks were waiting to bring the Key through the gateway."
    "Se indicó a varios soldados que esperaran fuera, donde varios camiones aguardaban para llevar la Llave a través del portal."

# game/episode019.rpy:283
translate spanish ep019_temple_6e72f3d7:

#   "It would then be airlifted out of the city and brought on the Jaculus, which was still orbiting Taagmar."
    "A continuación, se transportaría por aire fuera de la ciudad y se subiría al Jaculus, que seguía orbitando Taagmar."

# game/episode019.rpy:284
translate spanish ep019_temple_1d50c60d:

#   "I directed the crew outside, to make sure we were on that transport back through the Grand Arch."
    "Dirigí la tripulación fuera, para asegurarse de que estábamos en ese transporte de vuelta a través del Gran Arco."

# game/episode019.rpy:285
translate spanish ep019_temple_a8ba1daa:

#   "The engineers were now ready to move the Key, so it wouldn't be long before they would bring the thing outside."
    "Los ingenieros ya estaban listos para mover la Llave, así que no tardarían en sacarla al exterior."

# game/episode019.rpy:290
translate spanish ep019_temple_1cd7546f:

#   "Soldiers were boarding trucks and several more could be seen in the distance, nearing the gateway."
    "Los soldados subían a los camiones y se veían varios más a lo lejos, acercándose al portal."

# game/episode019.rpy:291
translate spanish ep019_temple_cda26a02:

#   "One of the trucks didn't have a canopy, most likely because that one would be used to transport the artifact."
    "Uno de los camiones no tenía capota, probablemente porque se utilizaría para transportar el artefacto."

# game/episode019.rpy:293
translate spanish ep019_temple_2e2afbe4:

#   "I positioned myself near the co-driver's door, as the others boarded a truck nearby."
    "Me coloqué cerca de la puerta del copiloto, mientras los demás subían a un camión cercano."

# game/episode019.rpy:294
translate spanish ep019_temple_a407d1a1:

#   "Thyia was about to enter the driver's side of the truck when she was stopped by the foreman."
    "Thyia estaba a punto de entrar en el lado del conductor del camión cuando fue detenida por el capataz."

# game/episode019.rpy:297
translate spanish ep019_temple_89344524:

#   man "I'm under orders to drive this myself."
    man "Tengo órdenes de conducirlo yo mismo."

# game/episode019.rpy:298
translate spanish ep019_temple_c9b9c319:

#   man "Commander Agust doesn't trust anyone else to do so."
    man "El comandante Agust no confía en nadie más para hacerlo."

# game/episode019.rpy:299
translate spanish ep019_temple_947570a1:

#   "I nodded at Thyia, her body language clearly expressing she was at a loss over this snag in our plan."
    "Asentí a Thyia, su lenguaje corporal expresaba claramente que estaba desconcertada por este contratiempo en nuestro plan."

# game/episode019.rpy:301
translate spanish ep019_temple_08347b95:

#   "Ideally, we would have controlled the truck ourselves, so we could have broken away from the transport at an opportune moment."
    "Lo ideal habría sido controlar el camión nosotros mismos, para poder separarnos del transporte en el momento oportuno."

# game/episode019.rpy:303
translate spanish ep019_temple_320d281f:

#   "The presence of the foreman didn't complicate things that much, as I was still riding shotgun next to him."
    "La presencia del capataz no complicó mucho las cosas, ya que yo seguía yendo de copiloto a su lado."

# game/episode019.rpy:304
translate spanish ep019_temple_c531f992:

#   "The truck went through the gateway."
    "El camión atravesó el portal."

# game/episode019.rpy:305
translate spanish ep019_temple_5b72769f:

#   "There was a split second where I feared the Key would somehow interfere with our passage through the Arch and reduce us to atoms."
    "Hubo una fracción de segundo en la que temí que la Llave interfiriera de algún modo en nuestro paso por el Arco y nos redujera a átomos."

# game/episode019.rpy:307
translate spanish ep019_temple_06331d93:

#   "Nothing of the sort happened and suddenly we were speeding on the main road through the Taagmar capital."
    "No pasó nada de eso y de repente íbamos a toda velocidad por la carretera principal que atraviesa la capital de Taagmar."

# game/episode019.rpy:308
translate spanish ep019_temple_2a19894e:

#   "Thyia and the others were pulling up next to us."
    "Thyia y los demás se detuvieron junto a nosotros."

# game/episode019.rpy:309
translate spanish ep019_temple_79002ff0:

#   "First we had to clear the barricade, and then we would commandeer the truck."
    "Primero teníamos que despejar la barricada y luego requisar el camión."

# game/episode019.rpy:311
translate spanish ep019_temple_1108c2fb:

#   "The guards at the barricades waved us through without much scrutiny."
    "Los guardias de las barricadas nos hicieron pasar sin mucho escrutinio."

# game/episode019.rpy:312
translate spanish ep019_temple_ef92d291:

#   "They were clearly more interested in the glowing statue on the back of the truck."
    "Claramente estaban más interesados en la estatua brillante de la parte trasera del camión."

# game/episode019.rpy:314
translate spanish ep019_temple_9e0a5003:

#   "When we were out of sight, I signaled Thyia to get ready."
    "Cuando nos perdimos de vista, hice una señal a Thyia para que se preparara."

# game/episode019.rpy:315
translate spanish ep019_temple_8d5bbf2c:

#   "Thyia’s truck accelerated and overtook us."
    "El camión de Thyia aceleró y nos adelantó."

# game/episode019.rpy:317
translate spanish ep019_temple_6d359ccf:

#   "Several meters in front of us, she yanked the steering wheel to the left and hit the brakes, effectively blocking our way."
    "Varios metros por delante de nosotros, tiró del volante hacia la izquierda y pisó el freno, bloqueándonos el paso."

# game/episode019.rpy:319
translate spanish ep019_temple_cd6c0a11:

#   man "What the-!"
    man "¿Qué...?"

# game/episode019.rpy:321
translate spanish ep019_temple_b56885d2:

#   "The foreman slammed the brakes and tried to veer from the road."
    "El capataz frenó en seco e intentó desviarse de la carretera."

# game/episode019.rpy:323
translate spanish ep019_temple_8f98a943:

#   "Luckily, he didn’t succeed, but I was rather afraid the violence of his actions would launch the Key into the side of the road."
    "Por suerte, no lo consiguió, pero temí que la violencia de sus acciones lanzara la Llave contra el arcén."

# game/episode019.rpy:324
translate spanish ep019_temple_40778fe2:

#   man "What are those clowns doing?!"
    man "¡¿Qué están haciendo esos payasos?!"

# game/episode019.rpy:326
translate spanish ep019_temple_8486b5f8:

#   man "Why are you-"
    man "¿Por qué estás...?"

# game/episode019.rpy:327
translate spanish ep019_temple_87d6e233:

#   c "Step out of the truck."
    c "Sal del camión."

# game/episode019.rpy:329
translate spanish ep019_temple_2e737a41:

#   "The foreman got out where Aven and Thyia already had their guns trained on him."
    "El capataz salió donde Aven y Thyia ya tenían sus armas apuntándole."

# game/episode019.rpy:330
translate spanish ep019_temple_10a58e65:

#   "I marched him to the back of the truck."
    "Lo llevé a la parte trasera del camión."

# game/episode019.rpy:331
translate spanish ep019_temple_eb51f3bd:

#   c "We'll take it from here."
    c "Nosotros nos encargamos."

# game/episode019.rpy:332
translate spanish ep019_temple_336ab11e:

#   c "Run back to your master to tell him you've lost his precious cargo."
    c "Vuelve corriendo con tu amo para decirle que has perdido su preciada carga."

# game/episode019.rpy:333
translate spanish ep019_temple_b7c41c97:

#   c "I'm sure he'll understand."
    c "Seguro que lo entenderá."

# game/episode019.rpy:335
translate spanish ep019_temple_e403dd9e:

#   man "You treacherous motherfucker."
    man "Hijo de puta traicionero."

# game/episode019.rpy:336
translate spanish ep019_temple_78dedcc9:

#   man "You won't get a dime, if you're planning on selling that thing on the black market."
    man "No conseguirás ni un centavo, si planeas vender esa cosa en el mercado negro."

# game/episode019.rpy:337
translate spanish ep019_temple_e7e410c7:

#   man "The Sovereignty will hunt you down for sure!"
    man "¡La Soberanía te cazará seguro!"

# game/episode019.rpy:338
translate spanish ep019_temple_4aac41ce:

#   c "We'll manage."
    c "Nos las arreglaremos."

# game/episode019.rpy:339
translate spanish ep019_temple_26fff1da:

#   c "Bye now."
    c "Adiós."

# game/episode019.rpy:340
translate spanish ep019_temple_662f4814:

#   "My gun still pointed at the foreman, I backtracked and got back into the truck."
    "Con la pistola aún apuntando al capataz, retrocedí y volví a subir al camión."

# game/episode019.rpy:342
translate spanish ep019_temple_49a9e0a8:

#   "Thyia had already started the engines, and we sped away as soon as I was back in my seat."
    "Thyia ya había puesto en marcha los motores y partimos en cuanto volví a mi asiento."

# game/episode019.rpy:344
translate spanish ep019_temple_bc28cfe7:

#   "The foreman was visible in the rear view mirror, his fist raised in futile rage."
    "El capataz se veía por el retrovisor, con el puño en alto en señal de rabia inútil."

# game/episode019.rpy:345
translate spanish ep019_temple_5dd08001:

#   "We didn't drive to Glixken's ship directly, to keep the foreman in the dark about our destination."
    "No fuimos directamente a la nave de Glixken, para que el capataz no supiera nuestro destino."

# game/episode019.rpy:346
translate spanish ep019_temple_8467c672:

#   "The fighting in the capital had all but died down, so we didn't encounter any resistance or even any patrols."
    "Los combates en la capital casi habían cesado, así que no encontramos resistencia ni patrullas."

# game/episode019.rpy:348
translate spanish ep019_temple_4532c99a:

#   "Our ticket out of the warzone was still parked in the same place we left it, unscathed."
    "Nuestro billete de salida de la zona de guerra seguía aparcado en el mismo lugar donde lo dejamos, indemne."

# game/episode019.rpy:349
translate spanish ep019_temple_53a8eb3a:

#   "The unearthing of the Key must have occupied everyone's minds on the Jaculus, so the reappearance of Glixken's ship had remained unnoticed."
    "El desenterramiento de la Llave debía de ocupar las mentes de todos en el Jaculus, por lo que la reaparición de la nave de Glixken había pasado desapercibida."

# game/episode019.rpy:350
translate spanish ep019_temple_841cc941:

#   "Luckily, the cargo bay of the ship was large enough to house the truck, so we just drove it inside after lowering the door of the hold."
    "Por suerte, el hangar de carga del barco era lo bastante grande para albergar el camión, así que nos limitamos a meterlo dentro tras bajar la puerta de la bodega."

# game/episode019.rpy:351
translate spanish ep019_temple_990ca99a:

#   "The rest of the crew abandoned the other truck and headed into Glixken's former ship as well."
    "El resto de la tripulación abandonó el otro camión y se dirigió también a la antigua nave de Glixken."

# game/episode019.rpy:352
translate spanish ep019_temple_2ad650cd:

#   "Within minutes after the truck was safely in the cargo and Céline was at her place behind the controls, we were ready for take-off."
    "Pocos minutos después de que el camión estuviera a salvo en la carga y Céline en su sitio tras los mandos, estábamos listos para despegar."

# game/episode019.rpy:354
translate spanish ep019_temple_0d171973:

#   "We punched through the atmosphere uncontested and found ourselves among the capital ships orbiting the planet."
    "Atravesamos la atmósfera sin oposición y nos encontramos entre las naves capitales que orbitan el planeta."

# game/episode019.rpy:355
translate spanish ep019_temple_1844c8a3:

#   "Céline set a course out of the system."
    "Céline puso rumbo fuera del sistema."

# game/episode019.rpy:356
translate spanish ep019_temple_553fbc73:

#   "From there we would make our way back to the station where the Bastard was parked, adding a couple of random jumps to throw off anyone who might follow us."
    "Desde allí volveríamos a la estación donde estaba aparcado el Bastardo, añadiendo un par de saltos aleatorios para despistar a cualquiera que pudiera seguirnos."

# game/episode019.rpy:358
translate spanish ep019_temple_31bfe374:

#   "None of the capital ships signaled us, so either the alarm hadn't been raised planet side yet, or nobody had connected the theft to the appearance of Glixken's ship near Taagmar."
    "Ninguna de las naves capitales nos hizo señales, así que o bien la alarma no había saltado aún en el planeta, o bien nadie había relacionado el robo con la aparición de la nave de Glixken cerca de Taagmar."

# game/episode019.rpy:359
translate spanish ep019_temple_f7b17662:

#   "As soon as we were clear of the Sovereignty blockade, Céline prepared the ship to Burst."
    "En cuanto nos libramos del bloqueo del Soberano, Céline preparó la nave para estallar."

# game/episode019.rpy:360
translate spanish ep019_temple_b675ce47:

#   "With the push of a button we let the Sovereignty-ravaged system behind us."
    "Pulsando un botón dejamos atrás el sistema devastado por la soberanía."

# game/episode019.rpy:366
translate spanish ep019_transit_eva_364a4a0c:

#   "The detour back to the station would take a few hours, so most of the crew opted to take a short rest."
    "El desvío de vuelta a la estación llevaría unas horas, así que la mayoría de la tripulación optó por tomarse un breve descanso."

# game/episode019.rpy:367
translate spanish ep019_transit_eva_1c057db9:

#   "I wandered the corridors of the ship, longing to be back in the familiarity of the Bastard."
    "Vagué por los pasillos de la nave, deseando volver a la familiaridad del Bastardo."

# game/episode019.rpy:369
translate spanish ep019_transit_eva_7d94621b:

#   "Eventually, I found myself near the cargo bay and was surprised to find Eva there."
    "Finalmente, me encontré cerca de la bahía de carga y me sorprendió encontrar allí a Eva."

# game/episode019.rpy:371
translate spanish ep019_transit_eva_8155b7d9:

#   c "Admiring the booty we stole from dad?"
    c "¿Admirando el botín que le robamos a papá?"

# game/episode019.rpy:373
translate spanish ep019_transit_eva_555c9b6a:

#   c "Admiring the booty we stole from my dad?"
    c "¿Admirando el botín que le robamos a mi padre?"

# game/episode019.rpy:375
translate spanish ep019_transit_eva_207b9b67:

#   "Eva didn't respond, staring intently at the glowing crystal strapped to the back of the truck."
    "Eva no respondió, mirando fijamente el cristal brillante atado a la parte trasera del camión."

# game/episode019.rpy:376
translate spanish ep019_transit_eva_b3e5f9d5:

#   c "Eva?"
    c "¿Eva?"

# game/episode019.rpy:378
translate spanish ep019_transit_eva_9735a5e3:

#   "When I touched her shoulder, Eva looked at me, startled."
    "Cuando le toqué el hombro, Eva me miró, sobresaltada."

# game/episode019.rpy:379
translate spanish ep019_transit_eva_8ff1f8ab:

#   e "Oh...{w} Hey, [p_name_short]."
    e "Oh...{w} Hey, [p_name_short]."

# game/episode019.rpy:380
translate spanish ep019_transit_eva_85fa53a0:

#   c "You were miles away."
    c "Estabas a kilómetros de distancia."

# game/episode019.rpy:382
translate spanish ep019_transit_eva_22e882d3:

#   e "I guess I was."
    e "Supongo que sí."

# game/episode019.rpy:384
translate spanish ep019_transit_eva_e4fd5f00:

#   e "This thing is fascinating though."
    e "Sin embargo, esta cosa es fascinante."

# game/episode019.rpy:385
translate spanish ep019_transit_eva_ac93c66c:

#   c "I just wish we knew what it unlocks, it's called the Key, after all."
    c "Ojalá supiéramos qué abre, al fin y al cabo se llama la Llave."

# game/episode019.rpy:386
translate spanish ep019_transit_eva_e1220635:

#   e "It seems ancient, yet also still alive."
    e "Parece antiguo, pero también vivo."

# game/episode019.rpy:387
translate spanish ep019_transit_eva_ff84a882:

#   c "It does look lively, for a crystal."
    c "Parece animado, para ser un cristal."

# game/episode019.rpy:388
translate spanish ep019_transit_eva_b859cf27:

#   c "Must be the pulsating glow, almost like a heartbeat."
    c "Debe ser el brillo pulsante, casi como un latido."

# game/episode019.rpy:389
translate spanish ep019_transit_eva_4fef3055:

#   e "Exactly."
    e "Exactamente."

# game/episode019.rpy:392
translate spanish ep019_transit_eva_e1feccdb:

#   e "Mom still doesn't have a clue what it is?"
    e "¿Mamá todavía no tiene ni idea de lo que es?"

# game/episode019.rpy:394
translate spanish ep019_transit_eva_3da453c1:

#   e "Nadya still doesn't have a clue what it is?"
    e "¿Nadya todavía no tiene ni idea de lo que es?"

# game/episode019.rpy:395
translate spanish ep019_transit_eva_0265d7bf:

#   c "I'm afraid not."
    c "Me temo que no."

# game/episode019.rpy:396
translate spanish ep019_transit_eva_386b8f33:

#   c "But I'm sure she'll think of someone we can contact about this, an expert on dusty alien space crystals."
    c "Pero estoy seguro de que se le ocurrirá alguien con quien podamos contactar sobre esto, un experto en polvorientos cristales espaciales alienígenas."

# game/episode019.rpy:397
translate spanish ep019_transit_eva_27157b12:

#   c "If this rock turns out to be some sort of decorative object we're all going to be sorely disappointed."
    c "Si esta roca resulta ser algún tipo de objeto decorativo, nos llevaremos una gran decepción."

# game/episode019.rpy:400
translate spanish ep019_transit_eva_b3752f63:

#   e "Not much chance of it, the Confessor and dad were far too eager to get their hands on it."
    e "No hay muchas posibilidades, la Confesora y papá estaban demasiado ansiosos por ponerle las manos encima."

# game/episode019.rpy:402
translate spanish ep019_transit_eva_0eeb2bef:

#   e "Not much chance of it, the Confessor and Agust were far too eager to get their hands on it."
    e "No hay muchas posibilidades, la Confesora y Agust estaban demasiado ansiosos por ponerle las manos encima."

# game/episode019.rpy:403
translate spanish ep019_transit_eva_8e526f8b:

#   e "They have information about this thing that we currently lack."
    e "Tienen información sobre esta cosa de la que actualmente carecemos."

# game/episode019.rpy:404
translate spanish ep019_transit_eva_053832f0:

#   c "It seems so."
    c "Eso parece."

# game/episode019.rpy:406
translate spanish ep019_transit_eva_1f9b0a0d:

#   c "That's why I have high hopes of Mom finding someone who knows more."
    c "Por eso tengo muchas esperanzas de que mamá encuentre a alguien que sepa más."

# game/episode019.rpy:408
translate spanish ep019_transit_eva_81015c1a:

#   c "That's why I have high hopes of Nadya finding someone who knows more."
    c "Por eso tengo muchas esperanzas de que Nadya encuentre a alguien que sepa más."

# game/episode019.rpy:410
translate spanish ep019_transit_eva_d22870db:

#   e "Let's hope she does."
    e "Esperemos que lo haga."

# game/episode019.rpy:417
translate spanish ep019_transit_ziv_e36c1e52:

#   "Ziv was lounging in the mess hall of the ship."
    "Ziv estaba descansando en el comedor de la nave."

# game/episode019.rpy:418
translate spanish ep019_transit_ziv_3bb069b4:

#   zi "[p_name_short], could I have a word with you?"
    zi "[p_name_short], ¿podría hablar contigo?"

# game/episode019.rpy:419
translate spanish ep019_transit_ziv_4e8c7062:

#   c "Of course."
    c "Por supuesto."

# game/episode019.rpy:421
translate spanish ep019_transit_ziv_8fa2461c:

#   zi "I’ve been thinking about our conversation the other day."
    zi "He estado pensando en nuestra conversación del otro día."

# game/episode019.rpy:425
translate spanish ep019_transit_ziv_6e240bf8:

#   zi "The fact that you didn’t trust me enough to tell me about the other woman hurts, I can’t deny that."
    zi "El hecho de que no confiaras en mí lo suficiente como para hablarme de la otra mujer duele, no puedo negarlo."

# game/episode019.rpy:427
translate spanish ep019_transit_ziv_e3d67e8b:

#   zi "The fact that you didn’t trust me enough to tell me about the other women hurts, I can’t deny that."
    zi "El hecho de que no confiaras en mí lo suficiente como para hablarme de las otras mujeres duele, no puedo negarlo."

# game/episode019.rpy:428
translate spanish ep019_transit_ziv_affdbf8e:

#   zi "However, the thought of ending things with you filled me with such sadness."
    zi "Sin embargo, la idea de acabar contigo me llenaba de tristeza."

# game/episode019.rpy:430
translate spanish ep019_transit_ziv_03998cbc:

#   zi "We’ve started this adventure together and it has always felt so good."
    zi "Hemos empezado esta aventura juntos y siempre nos hemos sentido muy bien."

# game/episode019.rpy:431
translate spanish ep019_transit_ziv_6c46b846:

#   zi "I don’t want to lose that."
    zi "No quiero perder eso."

# game/episode019.rpy:433
translate spanish ep019_transit_ziv_b9d98c59:

#   zi "I know your outlook on love differs from mine, so I’m not going to ask you to stop seeing that other girl."
    zi "Sé que tu visión del amor difiere de la mía, así que no voy a pedirte que dejes de ver a esa otra chica."

# game/episode019.rpy:435
translate spanish ep019_transit_ziv_73aada7a:

#   zi "I know your outlook on love differs from mine, so I’m not going to ask you to stop seeing those other girls."
    zi "Sé que tu visión del amor difiere de la mía, así que no voy a pedirte que dejes de ver a esas otras chicas."

# game/episode019.rpy:437
translate spanish ep019_transit_ziv_d038d877:

#   zi "I just want us to be able to love each other."
    zi "Sólo quiero que seamos capaces de querernos."

# game/episode019.rpy:438
translate spanish ep019_transit_ziv_83b2fe04:

#   zi "I love you, [p_name]."
    zi "Te quiero, [p_name]."

# game/episode019.rpy:439
translate spanish ep019_transit_ziv_be0aa889:

#   c "I love you too, Ziv."
    c "Yo también te quiero, Ziv."

# game/episode019.rpy:440
translate spanish ep019_transit_ziv_6f5b55ba:

#   c "And I’m sorry my actions have caused you so much pain, that was never my intention."
    c "Y siento que mis acciones te hayan causado tanto dolor, esa nunca fue mi intención."

# game/episode019.rpy:441
translate spanish ep019_transit_ziv_5d419388:

#   c "Lying about complicated stuff seemed like the easy way out, but it always comes back at you in the end."
    c "Mentir sobre cosas complicadas parecía la salida fácil, pero al final siempre se vuelve contra ti."

# game/episode019.rpy:443
translate spanish ep019_transit_ziv_4b760e9b:

#   "The kiss we exchanged as I sat beside her, sealed our renewed pledge to one another."
    "El beso que nos dimos cuando me senté a su lado selló nuestro compromiso mutuo."

# game/episode019.rpy:445
translate spanish ep019_transit_ziv_ccbcacea:

#   zi "Once we have a quiet moment to ourselves, I want us to make love like never before, [p_name]."
    zi "Una vez que tengamos un momento tranquilo para nosotros, quiero que hagamos el amor como nunca antes, [p_name]."

# game/episode019.rpy:446
translate spanish ep019_transit_ziv_4dc03407:

#   c "I’m going to hold you to that."
    c "Voy a hacer que lo cumplas."

# game/episode019.rpy:447
translate spanish ep019_transit_ziv_ee241385:

#   zi "Good!"
    zi "¡Bien!"

# game/episode019.rpy:453
translate spanish ep019_transit_ziv_ca08067f:

#   zi "And we need to end things."
    zi "Y tenemos que poner fin a las cosas."

# game/episode019.rpy:454
translate spanish ep019_transit_ziv_c850444c:

#   "Her statement didn’t come as much of a shock."
    "Su afirmación no me sorprendió demasiado."

# game/episode019.rpy:456
translate spanish ep019_transit_ziv_30ec7fab:

#   zi "I can’t be with someone who doesn’t treat me with respect."
    zi "No puedo estar con alguien que no me trata con respeto."

# game/episode019.rpy:457
translate spanish ep019_transit_ziv_e1071b09:

#   zi "You thought you could lie to me in order to get out of a complicated situation."
    zi "Pensaste que podías mentirme para salir de una situación complicada."

# game/episode019.rpy:459
translate spanish ep019_transit_ziv_f9a7b20c:

#   zi "That’s not a relationship I want to commit to."
    zi "Esa no es una relación a la que quiera comprometerme."

# game/episode019.rpy:460
translate spanish ep019_transit_ziv_7963cf59:

#   c "Understood."
    c "Entendido."

# game/episode019.rpy:464
translate spanish ep019_transit_ziv_71cde989:

#   c "I didn’t mean to disrespect you and I’m sorry."
    c "No quería faltarte al respeto y lo siento."

# game/episode019.rpy:466
translate spanish ep019_transit_ziv_0413526b:

#   c "So, my apologies for offending you, and I do hope we can still be friends."
    c "Le pido disculpas por haberle ofendido y espero que podamos seguir siendo amigos."

# game/episode019.rpy:468
translate spanish ep019_transit_ziv_0fbc0ef7:

#   "Ziv nodded appreciatively and smiled."
    "Ziv asintió agradecido y sonrió."

# game/episode019.rpy:469
translate spanish ep019_transit_ziv_b4ab4577:

#   zi "We can."
    zi "Podemos."

# game/episode019.rpy:470
translate spanish ep019_transit_ziv_a49acde8:

#   zi "Thank you, [p_name]."
    zi "Gracias, [p_name]."

# game/episode019.rpy:473
translate spanish ep019_transit_ziv_7d42ac0e:

#   "I didn’t have much else to say, so I left Ziv in the mess, ignoring her disappointed expression."
    "No tenía mucho más que decir, así que dejé a Ziv en el lío, ignorando su expresión de decepción."

# game/episode019.rpy:465
translate spanish ep019_transit_ziv_5d419388_1:

#   c "Lying about complicated stuff seemed like the easy way out, but it always comes back at you in the end."
    c "Mentir sobre cosas complicadas parecía la salida fácil, pero al final siempre se vuelve contra ti."

# game/episode019.rpy:481
translate spanish ep019_docked_58722793:

#   "Finally, we reached the station where the Bastard was docked."
    "Finalmente, llegamos a la estación donde estaba atracado el Bastard."

# game/episode019.rpy:483
translate spanish ep019_docked_81ce0f01:

#   "Céline landed Glixken's ship in the same hangar bay, and we began the unloading of the Key."
    "Céline aterrizó la nave de Glixken en el mismo hangar y comenzamos la descarga de la Llave."

# game/episode019.rpy:485
translate spanish ep019_docked_58492838:

#   "Thyia fetched two portable carriers from the Bastard's hold to load the artifact onto."
    "Thyia cogió dos portadores portátiles de la bodega del Bastardo para cargar en ellos el artefacto."

# game/episode019.rpy:487
translate spanish ep019_docked_7eede0d9:

#   "After driving the truck near the carriers, Jade went out to man the controls of a large crane."
    "Tras acercar el camión a los transportistas, Jade salió a manejar los mandos de una gran grúa."

# game/episode019.rpy:489
translate spanish ep019_docked_61dd1d5c:

#   "Using the crane, she managed to get the Key from the back of the truck and dumped onto the carriers."
    "Utilizando la grúa, consiguió sacar la llave de la parte trasera del camión y volcarla sobre los soportes."

# game/episode019.rpy:491
translate spanish ep019_docked_3d2d9e97:

#   "Slowly, the remote-operated carriers drove the Key into the Bastard's cargo bay."
    "Lentamente, los portadores teledirigidos introdujeron la Llave en el hangar de carga del Bastardo."

# game/episode019.rpy:493
translate spanish ep019_docked_62cd2dfc:

#   "Thyia paid the bill for the Bastard's maintenance."
    "Thyia pagó la factura del mantenimiento del Bastardo."

# game/episode019.rpy:494
translate spanish ep019_docked_3cd0ba2e:

#   "At first, we'd been planning on selling Glixken's ship to cover the repairs, but we didn't want to risk the Sovereignty finding the vessel and tracing it back to us."
    "Al principio, habíamos pensado vender el barco de Glixken para cubrir las reparaciones, pero no queríamos arriesgarnos a que el Soberano encontrara el barco y lo rastreara hasta nosotros."

# game/episode019.rpy:496
translate spanish ep019_docked_a334fbd6:

#   "Jade wiped much of the navigational history from Altum Station and onwards."
    "Jade borró gran parte de la historia de la navegación desde la estación de Altum en adelante."

# game/episode019.rpy:497
translate spanish ep019_docked_671f8956:

#   "Together with Céline, she programmed the computer to execute a series of jumps towards a faraway system."
    "Junto con Céline, programó el ordenador para ejecutar una serie de saltos hacia un sistema lejano."

# game/episode019.rpy:498
translate spanish ep019_docked_c2c4c9ce:

#   "From there the computer would start to record its route again and begin a long automated journey, traveling to random places."
    "A partir de ahí, el ordenador empezaría a grabar de nuevo su ruta y comenzaría un largo viaje automatizado, recorriendo lugares aleatorios."

# game/episode019.rpy:500
translate spanish ep019_docked_49a3c830:

#   "If the empty ship was ever intercepted by the Sovereignty, they'd have a hard time piecing together what happened with Glixken and his crew."
    "Si la nave vacía llegara a ser interceptada por el Soberano, les sería difícil averiguar qué pasó con Glixken y su tripulación."

# game/episode019.rpy:501
translate spanish ep019_docked_f4d7e7df:

#   "The rest of the crew worked on getting the Bastard ready for take-off."
    "El resto de la tripulación se dedicó a preparar el Bastardo para el despegue."

# game/episode019.rpy:504
translate spanish ep019_docked_e2e3e618:

#   "I decided to pay my mother a visit, to find out if she'd made some progress with finding an expert on massive glowing crystals."
    "Decidí hacer una visita a mi madre para saber si había hecho algún progreso en la búsqueda de un experto en cristales brillantes masivos."

# game/episode019.rpy:505
translate spanish ep019_docked_065c4db7:

#   c "Hey mom, still hitting the books?"
    c "Hola mamá, ¿sigues dándole a los libros?"

# game/episode019.rpy:507
translate spanish ep019_docked_ca3dfd09:

#   "I decided to pay Nadya a visit, to find out if she'd made some progress with finding an expert on massive glowing crystals."
    "Decidí hacer una visita a Nadya para saber si había hecho algún progreso en la búsqueda de un experto en cristales brillantes masivos."

# game/episode019.rpy:508
translate spanish ep019_docked_58e84874:

#   c "Hey Nadya, still hitting the books?"
    c "Hola Nadya, ¿sigues con los libros?"

# game/episode019.rpy:510
translate spanish ep019_docked_c2791676:

#   na "Yes, I still am."
    na "Sí, todavía lo estoy."

# game/episode019.rpy:511
translate spanish ep019_docked_8cf94f1d:

#   na "It's such a frustratingly broad subject."
    na "Es un tema tan frustrantemente amplio."

# game/episode019.rpy:512
translate spanish ep019_docked_39bb11ba:

#   na "Equal amounts of peer-reviewed science and speculative drivel."
    na "Cantidades iguales de ciencia revisada por expertos y de tonterías especulativas."

# game/episode019.rpy:513
translate spanish ep019_docked_369760b3:

#   c "I reckon it's hard to separate the two?"
    c "Creo que es difícil separar las dos cosas..."

# game/episode019.rpy:515
translate spanish ep019_docked_78560113:

#   na "The obvious nutcases are easy to weed out, but what remains is still a lot of ground to cover."
    na "Los locos obvios son fáciles de eliminar, pero lo que queda es todavía mucho terreno por cubrir."

# game/episode019.rpy:516
translate spanish ep019_docked_d30ac98f:

#   na "We're not the first to find an artifact like this and in many cases, the original creators didn't leave behind any notes on the creation or uses of the objects."
    na "No somos los primeros en encontrar un artefacto de este tipo y, en muchos casos, los creadores originales no dejaron ninguna nota sobre la creación o los usos de los objetos."

# game/episode019.rpy:517
translate spanish ep019_docked_9343f83a:

#   c "You're saying that identical objects have been found elsewhere?"
    c "¿Dice que se han encontrado objetos idénticos en otros lugares?"

# game/episode019.rpy:519
translate spanish ep019_docked_1d02aade:

#   na "No, just similar objects."
    na "No, sólo objetos similares."

# game/episode019.rpy:520
translate spanish ep019_docked_11795723:

#   na "Crystals in all sizes and forms, glowing rocks, that sort of stuff."
    na "Cristales de todos los tamaños y formas, rocas brillantes, ese tipo de cosas."

# game/episode019.rpy:521
translate spanish ep019_docked_5c76b170:

#   na "I know the artifact we took looks very much like a crystal, but we can't be sure it is."
    na "Sé que el artefacto que tomamos se parece mucho a un cristal, pero no podemos estar seguros de que lo sea."

# game/episode019.rpy:522
translate spanish ep019_docked_74085db3:

#   c "You're suggesting to have a gemologist take a look at it first?"
    c "¿Sugieres que primero lo vea un gemólogo?"

# game/episode019.rpy:524
translate spanish ep019_docked_a2d046fc:

#   na "Not really, just that we need to keep an open mind."
    na "En realidad no, sólo que debemos mantener la mente abierta."

# game/episode019.rpy:525
translate spanish ep019_docked_8e780940:

#   na "There are a lot of theories about alien crystals that were found across the galaxy."
    na "Hay muchas teorías sobre los cristales alienígenas que se encontraron por toda la galaxia."

# game/episode019.rpy:526
translate spanish ep019_docked_de110509:

#   na "Some say that older civilizations recorded data on them, navigational or otherwise."
    na "Algunos dicen que civilizaciones más antiguas grabaron datos en ellos, de navegación o de otro tipo."

# game/episode019.rpy:527
translate spanish ep019_docked_07f11b7a:

#   na "Others have posited that they could be an energy source, due to their pulsating glow and the fact that some of them appear to be electrically charged."
    na "Otros han postulado que podrían ser una fuente de energía, debido a su brillo pulsante y al hecho de que algunas de ellas parecen estar cargadas eléctricamente."

# game/episode019.rpy:528
translate spanish ep019_docked_9a1a34b0:

#   na "Then there's a school of thought that categorizes most of the crystal finds as objects used in religious rituals."
    na "También hay una corriente de pensamiento que clasifica la mayoría de los hallazgos de cristal como objetos utilizados en rituales religiosos."

# game/episode019.rpy:529
translate spanish ep019_docked_599fa4d5:

#   na "All plausible, but it doesn't bring us much further toward an understanding of the nature of our crystal."
    na "Todo plausible, pero no nos lleva mucho más lejos en la comprensión de la naturaleza de nuestro cristal."

# game/episode019.rpy:530
translate spanish ep019_docked_a590356e:

#   c "This is not your area of expertise either, right?"
    c "Tampoco es tu especialidad, ¿verdad?"

# game/episode019.rpy:532
translate spanish ep019_docked_8739870f:

#   na "That's another complication."
    na "Esa es otra complicación."

# game/episode019.rpy:533
translate spanish ep019_docked_60e2a7f6:

#   na "I know of a research group in Ketnar Kenesh that specializes in these kind of things and might be able to examine the Key more thoroughly."
    na "Conozco un grupo de investigación en Ketnar Kenesh que se especializa en este tipo de cosas y podría examinar la Clave más a fondo."

# game/episode019.rpy:534
translate spanish ep019_docked_791c07b7:

#   c "Can they be trusted?"
    c "¿Se puede confiar en ellos?"

# game/episode019.rpy:536
translate spanish ep019_docked_07fdf6f2:

#   na "Possibly."
    na "Posiblemente."

# game/episode019.rpy:537
translate spanish ep019_docked_5e121498:

#   na "They have no love for the Sovereignty, but that's not the only cutthroat power player with a vested interest currently in existence."
    na "No quieren a la Soberanía, pero no es el único actor de poder despiadado con intereses creados que existe actualmente."

# game/episode019.rpy:538
translate spanish ep019_docked_0ef7d519:

#   c "Flying around aimlessly with this thing in our cargo hold doesn't seem to be the best move."
    c "Volar sin rumbo con esta cosa en la bodega de carga no parece la mejor jugada."

# game/episode019.rpy:539
translate spanish ep019_docked_4e4449eb:

#   c "So maybe we should risk it."
    c "Así que quizá deberíamos arriesgarnos."

# game/episode019.rpy:540
translate spanish ep019_docked_56443929:

#   c "Give that research group access to the artifact, but with enough restrictions so that we can bail out as soon was we attract unwanted attention."
    c "Dar a ese grupo de investigación acceso al artefacto, pero con suficientes restricciones como para que podamos retirarnos en cuanto atraigamos una atención no deseada."

# game/episode019.rpy:542
translate spanish ep019_docked_f785d1c2:

#   na "Agreed."
    na "De acuerdo."

# game/episode019.rpy:543
translate spanish ep019_docked_74e91d40:

#   c "I'll inform the others."
    c "Informaré a los demás."

# game/episode019.rpy:544
translate spanish ep019_docked_c09bc293:

#   c "Could you send Céline the coordinates of Ketnar Kenesh?"
    c "¿Podrías enviarle a Céline las coordenadas de Ketnar Kenesh?"

# game/episode019.rpy:545
translate spanish ep019_docked_1e196086:

#   na "They operate out of a research station, orbiting an uninhabited moon."
    na "Operan desde una estación de investigación que orbita una luna deshabitada."

# game/episode019.rpy:546
translate spanish ep019_docked_8bbc1782:

#   na "It's quite remote and the base doesn't fall under any official jurisdiction."
    na "Está bastante alejada y la base no pertenece a ninguna jurisdicción oficial."

# game/episode019.rpy:547
translate spanish ep019_docked_afb2a600:

#   c "That doesn't sound like a bad place to get some answers."
    c "No parece un mal lugar para obtener algunas respuestas."

# game/episode019.rpy:548
translate spanish ep019_docked_30b61812:

#   c "I'll make sure we head out there as soon as possible."
    c "Me aseguraré de que vayamos allí lo antes posible."

# game/episode019.rpy:550
translate spanish ep019_docked_2ef111e3:

#   "When all the preparations were finished, Céline requested permission to leave the station."
    "Cuando terminaron todos los preparativos, Céline pidió permiso para salir de la estación."

# game/episode019.rpy:551
translate spanish ep019_docked_dbb9c116:

#   "Permission was granted almost immediately and both the Bastard and Glixken's former ship disengaged."
    "El permiso fue concedido casi de inmediato y tanto el Bastardo como la antigua nave de Glixken se retiraron."

# game/episode019.rpy:553
translate spanish ep019_docked_78d15dfa:

#   "The latter ship went through an automated undocking procedure, programmed by Jade and Céline."
    "Esta última nave se sometió a un procedimiento automatizado de desatraque, programado por Jade y Céline."

# game/episode019.rpy:554
translate spanish ep019_docked_4e4b5c04:

#   "When we'd put enough distance between us and the station, Céline ordered the other ship to begin its lonely journey through space, by randomly jumping to anywhere and nowhere."
    "Cuando habíamos puesto suficiente distancia entre nosotros y la estación, Céline ordenó a la otra nave que iniciara su solitario viaje por el espacio, saltando aleatoriamente a cualquier lugar y a ninguna parte."

# game/episode019.rpy:556
translate spanish ep019_docked_06b97df9:

#   "The Bastard set a course to the research station in Ketnar Kenesh."
    "El Bastardo puso rumbo a la estación de investigación de Ketnar Kenesh."

# game/episode019.rpy:557
translate spanish ep019_docked_07a30fbb:

#   "As the station was in a remote system, the journey would take a good while, requiring multiple jumps and gate passages."
    "Como la estación estaba en un sistema remoto, el viaje duraría un buen rato, ya que requeriría múltiples saltos y pasos por puertas."

# game/episode019.rpy:558
translate spanish ep019_docked_dada4534:

#   "We all indulged in some much-needed sleep."
    "Todos dormimos lo que tanto necesitábamos."

# game/episode019.rpy:559
translate spanish ep019_docked_c8192213:

#   "The unfamiliar confines of Glixken's ship made everyone uneasy, so nobody had managed a good night's rest while we transported the Key away from Taagmar."
    "Los confines desconocidos del barco de Glixken inquietaban a todo el mundo, así que nadie había conseguido descansar bien mientras transportábamos la Llave lejos de Taagmar."

# game/episode019.rpy:561
translate spanish ep019_docked_f332f617:

#   "My dreams were mercifully free from any Scolguin influence."
    "Mis sueños estaban misericordiosamente libres de cualquier influencia de Scolguin."

# game/episode019.rpy:566
translate spanish ep019_docked_0fc7a875:

#   "I awoke several hours later, because someone was banging on my door."
    "Me desperté varias horas después, porque alguien aporreaba mi puerta."

# game/episode019.rpy:567
translate spanish ep019_docked_1753e276:

#   l "[p_name]! Wake up!"
    l "[p_name]¡Despierta!"

# game/episode019.rpy:569
translate spanish ep019_docked_596b811e:

#   "Lilly sounded panicked so I was awake instantly and rushed to the door."
    "Lilly sonaba asustada, así que me desperté al instante y corrí hacia la puerta."

# game/episode019.rpy:570
translate spanish ep019_docked_3502305f:

#   c "What's the matter?"
    c "¿Cuál es el problema?"

# game/episode019.rpy:571
translate spanish ep019_docked_33611243:

#   l "Come quickly, it's Eva."
    l "Ven rápido, es Eva."

# game/episode019.rpy:572
translate spanish ep019_docked_6c6c7c02:

#   l "Something's wrong."
    l "Algo va mal."

# game/episode019.rpy:574
translate spanish ep019_docked_ab656f20:

#   "Lilly pulled me into the hallway and ushered me toward the cargo bay."
    "Lilly me sacó al pasillo y me condujo hacia el hangar de carga."

# game/episode019.rpy:575
translate spanish ep019_docked_1f40a094:

#   c "Lilly, what happened with Eva?"
    c "Lilly, ¿qué pasó con Eva?"

# game/episode019.rpy:577
translate spanish ep019_docked_263ae0bf:

#   l "I needed to use the restroom just now and noticed the door to Eva's room ajar."
    l "Necesitaba ir al baño y vi que la puerta de la habitación de Eva estaba entreabierta."

# game/episode019.rpy:578
translate spanish ep019_docked_4c24819b:

#   l "She wasn't in the restrooms, or in the mess."
    l "No estaba en los baños, ni en el comedor."

# game/episode019.rpy:579
translate spanish ep019_docked_6a5537ea:

#   l "Normally, I wouldn't look for her, but she's been behaving strangely ever since we left Taagmar."
    l "Normalmente, no la buscaría, pero se ha comportado de forma extraña desde que salimos de Taagmar."

# game/episode019.rpy:580
translate spanish ep019_docked_45b42f8b:

#   c "You mean her absentmindedness?"
    c "¿Te refieres a su despiste?"

# game/episode019.rpy:582
translate spanish ep019_docked_997aeee9:

#   l "Yes, like she's permanently lost in thought."
    l "Sí, como si estuviera permanentemente perdida en sus pensamientos."

# game/episode019.rpy:583
translate spanish ep019_docked_a18dc365:

#   l "So I checked everywhere and found her in the cargo bay."
    l "Así que busqué por todas partes y la encontré en la bahía de carga."

# game/episode019.rpy:584
translate spanish ep019_docked_e5f7cb4a:

#   l "Unconscious, next to the crystal."
    l "Inconsciente, junto al cristal."

# game/episode019.rpy:585
translate spanish ep019_docked_b437b351:

#   c "Fuck."
    c "Joder."

# game/episode019.rpy:588
translate spanish ep019_docked_656543a2:

#   c "Did you wake Thim?"
    c "¿Despertaste a Thim?"

# game/episode019.rpy:589
translate spanish ep019_docked_a8858f90:

#   l "I did."
    l "Lo hice."

# game/episode019.rpy:591
translate spanish ep019_docked_0d981d67:

#   c "Have you brought her to the medbay?"
    c "¿La has llevado a la enfermería?"

# game/episode019.rpy:593
translate spanish ep019_docked_0864c813:

#   l "I didn't know what to do, mom is with her now."
    l "No sabía qué hacer, mamá está con ella ahora."

# game/episode019.rpy:595
translate spanish ep019_docked_94ebdf74:

#   l "I didn't know what to do, Nadya is with her now."
    l "No sabía qué hacer, Nadya está con ella ahora."

# game/episode019.rpy:596
translate spanish ep019_docked_c32786ef:

#   "We'd reached the cargo bay."
    "Habíamos llegado al hangar de carga."

# game/episode019.rpy:599
translate spanish ep019_docked_129d07f3:

#   "Thim was already there, kneeling beside Eva."
    "Thim ya estaba allí, arrodillado junto a Eva."

# game/episode019.rpy:602
translate spanish ep019_docked_b013faca:

#   "Nadya was kneeling beside Eva."
    "Nadya estaba arrodillada junto a Eva."

# game/episode019.rpy:603
translate spanish ep019_docked_c2c211c4:

#   c "Is she still breathing?"
    c "¿Todavía respira?"

# game/episode019.rpy:606
translate spanish ep019_docked_270b5553:

#   t "She is, but she appears to be in a coma."
    t "Lo está, pero parece estar en coma."

# game/episode019.rpy:607
translate spanish ep019_docked_cd809cc8:

#   c "Is she fit enough to be moved to the medbay?"
    c "¿Está en condiciones de ser trasladada a la enfermería?"

# game/episode019.rpy:608
translate spanish ep019_docked_d616e7af:

#   t "Yes, she is."
    t "Sí, lo es."

# game/episode019.rpy:611
translate spanish ep019_docked_f335af49:

#   na "She is, but she won't wake up."
    na "Lo está, pero no se despierta."

# game/episode019.rpy:612
translate spanish ep019_docked_f0d0834a:

#   c "We need to get her to the medbay."
    c "Tenemos que llevarla a la enfermería."

# game/episode019.rpy:613
translate spanish ep019_docked_8d8e065c:

#   c "What the hell happened here?"
    c "¿Qué demonios ha pasado aquí?"

# game/episode019.rpy:615
translate spanish ep019_docked_2d77db88:

#   l "I don't know, I just found her lying here like this."
    l "No lo sé, sólo la encontré tirada aquí así."

# game/episode019.rpy:617
translate spanish ep019_docked_48a8e9a4:

#   "Only then I noticed the crystal, it wasn't glowing any longer."
    "Sólo entonces me di cuenta de que el cristal ya no brillaba."

# game/episode019.rpy:618
translate spanish ep019_docked_2e0fe575:

#   c "The Key seems to be inert."
    c "La Llave parece estar inerte."

# game/episode019.rpy:620
translate spanish ep019_docked_325b6ad7:

#   l "You're right, it's not pulsing anymore."
    l "Tienes razón, ya no late."

# game/episode019.rpy:621
translate spanish ep019_docked_832a10a9:

#   c "We'll worry about that later, first we need to get Eva inside the medbay."
    c "Nos preocuparemos de eso más tarde, primero tenemos que llevar a Eva a la enfermería."

# game/episode019.rpy:623
translate spanish ep019_docked_ecac9104:

#   "Eva didn't respond when we lifted her from the floor and carried her to the medbay."
    "Eva no respondió cuando la levantamos del suelo y la llevamos a la enfermería."

# game/episode019.rpy:626
translate spanish ep019_docked_5c8a8979:

#   t "I'm going to run some tests, but the lab here is very limited."
    t "Voy a hacer algunas pruebas, pero el laboratorio de aquí es muy limitado."

# game/episode019.rpy:627
translate spanish ep019_docked_e4f24456:

#   t "Depending on how deep her coma is, she'll need specialized care."
    t "Dependiendo de lo profundo que sea su coma, necesitará cuidados especializados."

# game/episode019.rpy:630
translate spanish ep019_docked_4ae607ee:

#   "The autodoc told us what we already feared, Eva had somehow slipped into a coma."
    "El autodoc nos dijo lo que ya nos temíamos: Eva había entrado en coma."

# game/episode019.rpy:631
translate spanish ep019_docked_031b2a10:

#   na "The autodoc is far too limited to treat a patient like this."
    na "El autodoc es demasiado limitado para tratar a un paciente así."

# game/episode019.rpy:632
translate spanish ep019_docked_bf906cc4:

#   na "Eva will likely need specialized care."
    na "Eva probablemente necesitará cuidados especializados."

# game/episode019.rpy:633
translate spanish ep019_docked_d9f1c857:

#   c "Then we'll make sure she gets it."
    c "Entonces nos aseguraremos de que lo consiga."

# game/episode019.rpy:634
translate spanish ep019_docked_4d4e0822:

#   c "Can you rouse the others, Lilly?"
    c "¿Puedes despertar a los demás, Lilly?"

# game/episode019.rpy:635
translate spanish ep019_docked_d5de3a65:

#   c "We'll need options, and fast."
    c "Necesitaremos opciones, y rápido."

# game/episode019.rpy:637
translate spanish ep019_docked_bf023ff1:

#   "The entire crew didn't fit into the medbay, so some of them waited in the hallway."
    "No cabía toda la tripulación en la enfermería, así que algunos esperaron en el pasillo."

# game/episode019.rpy:639
translate spanish ep019_docked_1d670aea:

#   th "So that artifact isn't radiating energy anymore?"
    th "¿Así que ese artefacto ya no irradia energía?"

# game/episode019.rpy:640
translate spanish ep019_docked_989e66b2:

#   c "Yes, it seems to be inert."
    c "Sí, parece inerte."

# game/episode019.rpy:641
translate spanish ep019_docked_948f39d5:

#   th "And Eva was lying in front of it?"
    th "¿Y Eva estaba tumbada delante?"

# game/episode019.rpy:643
translate spanish ep019_docked_5a8af982:

#   th "That can't be a coincidence."
    th "No puede ser una coincidencia."

# game/episode019.rpy:644
translate spanish ep019_docked_88df38a7:

#   c "Agreed."
    c "De acuerdo."

# game/episode019.rpy:645
translate spanish ep019_docked_a8a90472:

#   c "Ever since we got that thing out of the temple, Eva seemed strangely attracted to the Key."
    c "Desde que sacamos esa cosa del templo, Eva parecía extrañamente atraída por la Llave."

# game/episode019.rpy:646
translate spanish ep019_docked_249f91bb:

#   c "Like it was calling to her."
    c "Como si la llamara."

# game/episode019.rpy:648
translate spanish ep019_docked_bcd9c34a:

#   th "Maybe it was."
    th "Tal vez lo fuera."

# game/episode019.rpy:649
translate spanish ep019_docked_cd18facf:

#   th "It called to her to fulfill its function?"
    th "¿La llamó para que cumpliera su función?"

# game/episode019.rpy:651
translate spanish ep019_docked_2f22d255:

#   l "By putting her into a coma?"
    l "¿Poniéndola en coma?"

# game/episode019.rpy:653
translate spanish ep019_docked_6235794e:

#   na "That probably wasn't the desired outcome."
    na "Probablemente ese no era el resultado deseado."

# game/episode019.rpy:654
translate spanish ep019_docked_f3fcb313:

#   na "But if all that energy pent up in the crystal was spent at once..."
    na "Pero si toda esa energía acumulada en el cristal se gastara de una vez..."

# game/episode019.rpy:655
translate spanish ep019_docked_f9dacc52:

#   c "Whatever the reason for Eva's current state, she needs better medical care than we can provide here."
    c "Sea cual sea la razón del estado actual de Eva, necesita una atención médica mejor de la que podemos proporcionarle aquí."

# game/episode019.rpy:658
translate spanish ep019_docked_96599b0a:

#   t "She does."
    t "Lo hace."

# game/episode019.rpy:659
translate spanish ep019_docked_ebf19ab7:

#   t "There is a chance she'll wake up on her own."
    t "Existe la posibilidad de que se despierte sola."

# game/episode019.rpy:660
translate spanish ep019_docked_6839fe16:

#   t "But that isn't a given, and it's also unclear in what timeframe."
    t "Pero eso no es un hecho, y tampoco está claro en qué plazo."

# game/episode019.rpy:663
translate spanish ep019_docked_d22ec4b2:

#   c "According to the autodoc, there is a chance she'll wake up on her own."
    c "Según el autodoc, hay posibilidades de que se despierte sola."

# game/episode019.rpy:664
translate spanish ep019_docked_55951399:

#   c "But that isn't a given, and it's also unclear in what timeframe."
    c "Pero eso no es un hecho, y tampoco está claro en qué plazo."

# game/episode019.rpy:665
translate spanish ep019_docked_9ff1141e:

#   c "Céline, are there any medical facilities nearby?"
    c "Céline, ¿hay algún centro médico cerca?"

# game/episode019.rpy:667
translate spanish ep019_docked_8f23be73:

#   ce "Yes, there's one on Paclerara."
    ce "Sí, hay uno en Paclerara."

# game/episode019.rpy:670
translate spanish ep019_docked_cb8e9281:

#   "I noticed Jade's gaze snap to attention."
    "Noté que la mirada de Jade se fijaba en mí."

# game/episode019.rpy:671
translate spanish ep019_docked_cf08ff5e:

#   "Paclerara had been mentioned before, in relation to Jade's family."
    "Paclerara ya se había mencionado antes, en relación con la familia de Jade."

# game/episode019.rpy:672
translate spanish ep019_docked_50326c6f:

#   "Her mother was supposedly buried on the planet, her gravesite a place of pilgrimage."
    "Se supone que su madre fue enterrada en el planeta y que su tumba es un lugar de peregrinación."

# game/episode019.rpy:674
translate spanish ep019_docked_ca5af95c:

#   c "Paclerara’s medical facilities constitute of more than a first aid kit, right?"
    c "Las instalaciones médicas de Paclerara son algo más que un botiquín de primeros auxilios, ¿verdad?"

# game/episode019.rpy:675
translate spanish ep019_docked_5ebc3a6b:

#   ce "Yes, but it’s not a high-tech facility like Custer's Reach."
    ce "Sí, pero no es una instalación de alta tecnología como Custer's Reach."

# game/episode019.rpy:677
translate spanish ep019_docked_83675fc9:

#   c "We're not talking about some backwater place that happens to have a first aid kit, right?"
    c "No estamos hablando de un lugar de mala muerte que casualmente tiene un botiquín de primeros auxilios, ¿verdad?"

# game/episode019.rpy:678
translate spanish ep019_docked_295ae81b:

#   ce "No, but neither is it a high-tech facility, like Custer's Reach."
    ce "No, pero tampoco es una instalación de alta tecnología, como Custer's Reach."

# game/episode019.rpy:679
translate spanish ep019_docked_ec9f0df8:

#   c "It’ll have to do."
    c "Tendrá que servir."

# game/episode019.rpy:680
translate spanish ep019_docked_9cca7b00:

#   c "Céline, abandon our course to Ketnar Kenesh, Paclerara will be our first stop."
    c "Céline, abandona nuestro rumbo hacia Ketnar Kenesh, Paclerara será nuestra primera parada."

# game/episode019.rpy:681
translate spanish ep019_docked_ab05b18c:

#   ce "Understood."
    ce "Entendido."

# game/episode019.rpy:682
translate spanish ep019_docked_102452de:

#   "As Céline went to the bridge to plot the new route, the others left the medbay."
    "Mientras Céline se dirigía al puente para trazar la nueva ruta, los demás abandonaron la enfermería."

# game/episode019.rpy:687
translate spanish ep019_docked_63049f8d:

#   "Nadya lingered, clearly worried."
    "Nadya se quedó, claramente preocupada."

# game/episode019.rpy:688
translate spanish ep019_docked_609f21a3:

#   c "I should have paid more attention to Eva."
    c "Debería haber prestado más atención a Eva."

# game/episode019.rpy:690
translate spanish ep019_docked_6314aa85:

#   na "You couldn't know something like this would happen."
    na "No podías saber que algo así pasaría."

# game/episode019.rpy:691
translate spanish ep019_docked_c87b0ece:

#   na "Besides, she didn't exhibit any alarming symptoms, just the absentmindedness."
    na "Además, no presentaba ningún síntoma alarmante, sólo el despiste."

# game/episode019.rpy:692
translate spanish ep019_docked_b429ecb4:

#   c "Do you think the Key rendered her unconscious?"
    c "¿Crees que la Llave la dejó inconsciente?"

# game/episode019.rpy:693
translate spanish ep019_docked_e50daff3:

#   na "That seems a likely explanation."
    na "Parece una explicación probable."

# game/episode019.rpy:695
translate spanish ep019_docked_9ab56339:

#   na "Maybe expended energy overwhelmed her somehow."
    na "Tal vez la energía gastada la abrumó de alguna manera."

# game/episode019.rpy:696
translate spanish ep019_docked_4c06441a:

#   c "But why didn't it happen before, when we were stealing that thing from the temple?"
    c "Pero, ¿por qué no ocurrió antes, cuando robábamos esa cosa del templo?"

# game/episode019.rpy:697
translate spanish ep019_docked_b17d2579:

#   na "I'm not sure."
    na "No estoy seguro."

# game/episode019.rpy:698
translate spanish ep019_docked_bc25af62:

#   na "She was lying directly next to the crystal when Lilly found her in the cargo bay."
    na "Estaba tumbada junto al cristal cuando Lilly la encontró en el hangar de carga."

# game/episode019.rpy:699
translate spanish ep019_docked_2be685dd:

#   na "Eva didn't come that close to the Key before, or maybe she touched it, after being drawn towards it."
    na "Eva no se había acercado tanto a la Llave antes, o tal vez la tocó, después de sentirse atraída hacia ella."

# game/episode019.rpy:700
translate spanish ep019_docked_a7c34609:

#   na "Or maybe she was sleepwalking and her mental state had become more attuned to whatever signal the Key was sending to her."
    na "O tal vez era sonámbula y su estado mental se había vuelto más acorde con la señal que le enviaba la Llave."

# game/episode019.rpy:701
translate spanish ep019_docked_13251290:

#   c "Maybe."
    c "Tal vez."

# game/episode019.rpy:702
translate spanish ep019_docked_a851bb5a:

#   c "We've been wondering what the Key would unlock, maybe it unlocked something inside Eva?"
    c "Nos hemos estado preguntando qué abriría la Llave, ¿quizás abriera algo dentro de Eva?"

# game/episode019.rpy:704
translate spanish ep019_docked_156bee26:

#   na "Presuming both Eva and the Key are part of the prophecy, that seems likely."
    na "Suponiendo que tanto Eva como la Llave formen parte de la profecía, parece probable."

# game/episode019.rpy:705
translate spanish ep019_docked_9be8796c:

#   c "The fact that Agust and his coterie were after the Key all but confirms the thing is part of the prophecy."
    c "El hecho de que Agust y su camarilla fueran tras la Llave confirma que forma parte de la profecía."

# game/episode019.rpy:706
translate spanish ep019_docked_6a511e6f:

#   na "I'm afraid so."
    na "Me temo que sí."

# game/episode019.rpy:707
translate spanish ep019_docked_b51eb0f9:

#   na "Seeing as we won't be reaching Ketnar Kenesh anytime soon, I'll better get back to my studies."
    na "Como no llegaremos pronto a Ketnar Kenesh, será mejor que vuelva a mis estudios."

# game/episode019.rpy:708
translate spanish ep019_docked_4ae0ec52:

#   c "Good idea, let me know if you find anything."
    c "Buena idea, avísame si encuentras algo."

# game/episode019.rpy:710
translate spanish ep019_docked_c5b19451:

#   na "I will."
    na "Lo haré."

# game/episode019.rpy:711
translate spanish ep019_docked_b6cfd57d:

#   "Nadya and I both left the medbay."
    "Nadya y yo salimos de la enfermería."

# game/episode019.rpy:713
translate spanish ep019_docked_9d7a6c25:

#   "I went on to check on Lilly."
    "Fui a ver cómo estaba Lilly."

# game/episode019.rpy:714
translate spanish ep019_docked_51123a37:

#   c "Sorry, were you trying to get some sleep?"
    c "Perdona, ¿estabas intentando dormir un poco?"

# game/episode019.rpy:716
translate spanish ep019_docked_43f5c9e1:

#   l "I was, but without any success, I'm tired and yet I'm so afraid."
    l "Lo estaba, pero sin ningún éxito, estoy cansada y a la vez tengo mucho miedo."

# game/episode019.rpy:717
translate spanish ep019_docked_8fac0189:

#   c "Yeah, it must have been rough, finding Eva like that."
    c "Sí, debe haber sido duro, encontrar a Eva así."

# game/episode019.rpy:719
translate spanish ep019_docked_5747dc79:

#   l "It was, for a split second I thought she'd died..."
    l "Lo fue, por una fracción de segundo pensé que había muerto..."

# game/episode019.rpy:721
translate spanish ep019_docked_7f5477bb:

#   l "That I'd lost her again."
    l "Que la había vuelto a perder."

# game/episode019.rpy:723
translate spanish ep019_docked_831a9b2c:

#   "Lilly broke down in tears."
    "Lilly rompió a llorar."

# game/episode019.rpy:725
translate spanish ep019_docked_ef734e34:

#   "Part of me wanted to gather her up in my arms and console her, but past events prevented me from acting on it."
    "Una parte de mí quería estrecharla entre mis brazos y consolarla, pero los acontecimientos del pasado me lo impedían."

# game/episode019.rpy:726
translate spanish ep019_docked_501bb212:

#   "With obvious effort, Lilly composed herself again."
    "Con evidente esfuerzo, Lilly volvió a serenarse."

# game/episode019.rpy:728
translate spanish ep019_docked_aeb52c40:

#   l "I'm going to try again to get some sleep."
    l "Voy a intentar de nuevo dormir un poco."

# game/episode019.rpy:729
translate spanish ep019_docked_4e8c7062:

#   c "Of course."
    c "Por supuesto."

# game/episode019.rpy:730
translate spanish ep019_docked_3dec9420:

#   c "Eva will pull through, Lilly, I'm sure of it."
    c "Eva saldrá adelante, Lilly, estoy seguro de ello."

# game/episode019.rpy:732
translate spanish ep019_docked_8449a65b:

#   "Lilly nodded silently and I left her alone."
    "Lilly asintió en silencio y la dejé sola."

# game/episode019.rpy:735
translate spanish ep019_docked_9fbe50d1:

#   "I gathered her up in my arms and tried to console her."
    "La abracé e intenté consolarla."

# game/episode019.rpy:736
translate spanish ep019_docked_3aa1e6f3:

#   "Lilly's tears soaked my chest and it took her a good while to compose herself."
    "Las lágrimas de Lilly empaparon mi pecho y tardó un buen rato en serenarse."

# game/episode019.rpy:740
translate spanish ep019_docked_a87b89dd:

#   l "She must, [p_name_short], I don't want to lose her again!"
    l "Debe hacerlo, [p_name_short] ¡no quiero perderla otra vez!"

# game/episode019.rpy:742
translate spanish ep019_docked_68ccb3de:

#   l "Will you stay with me tonight?"
    l "¿Te quedarás conmigo esta noche?"

# game/episode019.rpy:744
translate spanish ep019_docked_b7ea8324:

#   l "I can't bear to be alone right now."
    l "No soporto estar sola ahora."

# game/episode019.rpy:748
translate spanish ep019_docked_90634673:

#   "I lay beside my sister in her bed and pulled her against me."
    "Me tumbé junto a mi hermana en su cama y la atraje contra mí."

# game/episode019.rpy:750
translate spanish ep019_docked_87800dd6:

#   "I lay beside Lilly in her bed and pulled her against me."
    "Me tumbé junto a Lilly en su cama y la atraje contra mí."

# game/episode019.rpy:751
translate spanish ep019_docked_d05f368c:

#   "She snuggled against my chest, relishing the feeling of protection it gave her."
    "Se acurrucó contra mi pecho, disfrutando de la sensación de protección que le proporcionaba."

# game/episode019.rpy:752
translate spanish ep019_docked_91ad4d4b:

#   "Her crying gradually subsided, and her breathing became more regular."
    "Su llanto disminuyó gradualmente y su respiración se hizo más regular."

# game/episode019.rpy:754
translate spanish ep019_docked_6cdecd78:

#   "Before long, she was fast asleep, and I slipped slowly into a dreamless sleep as well."
    "Al poco rato, se quedó profundamente dormida y yo también me sumí lentamente en un sueño sin sueños."

# game/episode019.rpy:756
translate spanish ep019_docked_aeff8283:

#   "Lilly kept crying until her sobbing gradually subsided and her breathing became more regular."
    "Lilly siguió llorando hasta que sus sollozos disminuyeron gradualmente y su respiración se hizo más regular."

# game/episode019.rpy:758
translate spanish ep019_docked_eb4fd037:

#   "When I was sure she'd fallen asleep, I eased her back onto her bed and slipped out of her bedroom."
    "Cuando me aseguré de que se había dormido, la volví a tumbar en la cama y salí de su habitación."

# game/episode019.rpy:738
translate spanish ep019_docked_3dec9420_1:

#   c "Eva will pull through, Lilly, I'm sure of it."
    c "Eva saldrá adelante, Lilly, estoy seguro de ello."

# game/episode019.rpy:745
translate spanish ep019_docked_4e8c7062_1:

#   c "Of course."
    c "Por supuesto."

# game/episode019.rpy:778
translate spanish ep019_paclerara_arrival_255179ec:

#   "Paclerara turned out to be a place full of teeming forests and expansive lakes."
    "Paclerara resultó ser un lugar lleno de bosques rebosantes y extensos lagos."

# game/episode019.rpy:779
translate spanish ep019_paclerara_arrival_52c06aac:

#   "Not a lot of the planet was inhabited, much of it still wilderness."
    "No había mucho planeta habitado, gran parte seguía siendo desierto."

# game/episode019.rpy:780
translate spanish ep019_paclerara_arrival_84aa884c:

#   "We flew over several smaller settlements, on our way to the largest concentration of people on the planet."
    "Sobrevolamos varios asentamientos menores, camino de la mayor concentración de población del planeta."

# game/episode019.rpy:782
translate spanish ep019_paclerara_arrival_5603bbe1:

#   "The Paclerara Residence supposedly housed several thousand and was the main port of the entire planet."
    "La Residencia Paclerara albergaba supuestamente a varios miles de personas y era el principal puerto de todo el planeta."

# game/episode019.rpy:783
translate spanish ep019_paclerara_arrival_cd524e23:

#   "Céline had messaged ahead, requesting a landing berth and medical assistance."
    "Céline había enviado un mensaje solicitando un amarradero y asistencia médica."

# game/episode019.rpy:785
translate spanish ep019_paclerara_arrival_e96b243f:

#   "A team of medics was already waiting when we touched down on one of the pads rising out of the water of the vast lake surrounding the Residence."
    "Un equipo de médicos ya estaba esperando cuando aterrizamos en una de las plataformas que surgen del agua del vasto lago que rodea la Residencia."

# game/episode019.rpy:787
translate spanish ep019_paclerara_arrival_b084c1df:

#   "Eva was transferred onto a gurney and hurried inside the Residence."
    "Trasladaron a Eva a una camilla y la llevaron a toda prisa al interior de la Residencia."

# game/episode019.rpy:789
translate spanish ep019_paclerara_arrival_137134f9:

#   "Lilly and I followed them, while the rest of the crew took care of the necessities surrounding the Bastard’s arrival on Paclerara."
    "Lilly y yo les seguimos, mientras el resto de la tripulación se ocupaba de las necesidades que rodeaban la llegada del Bastardo a Paclerara."

# game/episode019.rpy:790
translate spanish ep019_paclerara_arrival_2b779fbe:

#   "The architecture of the Residence was one of clear lines and the interior had that slightly glossy veneer of something newly built or immaculately maintained."
    "La arquitectura de la Residencia era de líneas claras y el interior tenía ese barniz ligeramente brillante de algo recién construido o inmaculadamente mantenido."

# game/episode019.rpy:792
translate spanish ep019_paclerara_arrival_e8d8f744:

#   "As was to be expected, a considerable percentage of the population were Twi’ll."
    "Como era de esperar, un porcentaje considerable de la población eran Twi'll."

# game/episode019.rpy:794
translate spanish ep019_paclerara_arrival_5b564346:

#   "A considerable percentage of the population turned out to be Twi’ll."
    "Un porcentaje considerable de la población resultó ser Twi'll."

# game/episode019.rpy:796
translate spanish ep019_paclerara_arrival_ed0f37cd:

#   "Eva was eventually rolled into a spacious room and placed on a medical bed."
    "Eva fue trasladada a una habitación espaciosa y colocada en una cama médica."

# game/episode019.rpy:798
translate spanish ep019_paclerara_arrival_b17926f3:

#   "One of the medics turned towards us."
    "Uno de los médicos se volvió hacia nosotros."

# game/episode019.rpy:800
translate spanish ep019_paclerara_arrival_16498fd4:

#   man "I assume you are family or close friends?"
    man "¿Supongo que son familia o amigos íntimos?"

# game/episode019.rpy:802
translate spanish ep019_paclerara_arrival_ce923d5a:

#   l "Brother and sister."
    l "Hermano y hermana."

# game/episode019.rpy:804
translate spanish ep019_paclerara_arrival_62da06f9:

#   l "Close friends."
    l "Amigos íntimos."

# game/episode019.rpy:805
translate spanish ep019_paclerara_arrival_a82608ad:

#   man "What happened to her?"
    man "¿Qué le ha pasado?"

# game/episode019.rpy:806
translate spanish ep019_paclerara_arrival_bf9eb9db:

#   "We’d figured out beforehand that we were going to be as upfront as possible about Eva’s state, without mentioning the artifact."
    "Habíamos decidido de antemano que íbamos a ser lo más francos posible sobre el estado de Eva, sin mencionar el artefacto."

# game/episode019.rpy:807
translate spanish ep019_paclerara_arrival_ff9ba400:

#   c "We found her one night, already comatose."
    c "La encontramos una noche, ya comatosa."

# game/episode019.rpy:808
translate spanish ep019_paclerara_arrival_fa989d9f:

#   l "She’d been sleepwalking and must have passed out."
    l "Había estado sonámbula y debió de desmayarse."

# game/episode019.rpy:809
translate spanish ep019_paclerara_arrival_550ad958:

#   man "Did she hit her head or was there any indication of head trauma?"
    man "¿Se golpeó la cabeza o había algún indicio de traumatismo craneal?"

# game/episode019.rpy:810
translate spanish ep019_paclerara_arrival_5500df07:

#   c "No, there wasn’t."
    c "No, no lo había."

# game/episode019.rpy:811
translate spanish ep019_paclerara_arrival_6d67cce6:

#   c "She had trouble sleeping before, as if she was restless, or something."
    c "Antes le costaba dormir, como si estuviera inquieta, o algo así."

# game/episode019.rpy:812
translate spanish ep019_paclerara_arrival_f033cef4:

#   c "But no concussion or anything."
    c "Pero sin conmoción ni nada."

# game/episode019.rpy:813
translate spanish ep019_paclerara_arrival_2b46399d:

#   man "Alright, we’ll have a physician have a look at her as soon as the paperwork has been filled out."
    man "De acuerdo, haremos que un médico le eche un vistazo en cuanto se haya rellenado el papeleo."

# game/episode019.rpy:814
translate spanish ep019_paclerara_arrival_ec234a80:

#   man "Are you staying here at the Residence?"
    man "¿Se aloja aquí en la Residencia?"

# game/episode019.rpy:815
translate spanish ep019_paclerara_arrival_1dcdb854:

#   c "We are, yes."
    c "Lo estamos, sí."

# game/episode019.rpy:816
translate spanish ep019_paclerara_arrival_0d59327d:

#   man "I’d suggest you book lodgings for several days."
    man "Te sugiero que reserves alojamiento para varios días."

# game/episode019.rpy:817
translate spanish ep019_paclerara_arrival_6ddcc09b:

#   man "Leave us your contact details, so we can notify you with any results."
    man "Déjanos tus datos de contacto para que podamos notificarte cualquier resultado."

# game/episode019.rpy:819
translate spanish ep019_paclerara_arrival_2b2fe0bd:

#   "We did as asked and went back to the landing area of the Residence."
    "Hicimos lo que nos pidieron y volvimos a la zona de aterrizaje de la Residencia."

# game/episode019.rpy:820
translate spanish ep019_paclerara_arrival_9c8cc722:

#   "Only Céline remained in the lobby."
    "Sólo Céline permaneció en el vestíbulo."

# game/episode019.rpy:822
translate spanish ep019_paclerara_arrival_23044de3:

#   ce "Is Eva in good hands?"
    ce "¿Está Eva en buenas manos?"

# game/episode019.rpy:823
translate spanish ep019_paclerara_arrival_058dd7b5:

#   c "Yes, I think so."
    c "Sí, creo que sí."

# game/episode019.rpy:825
translate spanish ep019_paclerara_arrival_aa9bdb33:

#   l "Where did everyone go?"
    l "¿Adónde han ido todos?"

# game/episode019.rpy:827
translate spanish ep019_paclerara_arrival_dd74b02c:

#   ce "We’ve booked rooms for the crew."
    ce "Hemos reservado habitaciones para la tripulación."

# game/episode019.rpy:828
translate spanish ep019_paclerara_arrival_f6f99f8a:

#   ce "Thyia was afraid it would be extremely expensive to house everyone in separate rooms, but apparently having a Twi’ll on the crew counts for a lot."
    ce "Thyia temía que resultara extremadamente caro alojar a todo el mundo en habitaciones separadas, pero al parecer contar con un Twi'll en la tripulación cuenta mucho."

# game/episode019.rpy:830
translate spanish ep019_paclerara_arrival_6193ee6f:

#   l "That must have been some discount."
    l "Debe haber sido un descuento."

# game/episode019.rpy:832
translate spanish ep019_paclerara_arrival_b0694f62:

#   ce "I believe Thyia was pretty happy with it."
    ce "Creo que Thyia estaba bastante contenta con él."

# game/episode019.rpy:834
translate spanish ep019_paclerara_arrival_1f961d90:

#   l "Great, in that case I’m going to check out my lodgings."
    l "Genial, en ese caso voy a comprobar mi alojamiento."

# game/episode019.rpy:835
translate spanish ep019_paclerara_arrival_cbf0bbba:

#   l "See if they include a bath."
    l "Averigua si incluyen un baño."

# game/episode019.rpy:836
translate spanish ep019_paclerara_arrival_5131978c:

#   ce "Now I’m curious too."
    ce "Ahora yo también tengo curiosidad."

# game/episode019.rpy:837
translate spanish ep019_paclerara_arrival_e0bc4b6c:

#   l "See you around, [p_name_short]."
    l "Nos vemos, [p_name_short]."

# game/episode019.rpy:839
translate spanish ep019_paclerara_arrival_549fb120:

#   "The girls left me and I decided to check out the room number Thyia had sent me a little while ago."
    "Las chicas me dejaron y decidí comprobar el número de habitación que Thyia me había enviado hacía un rato."

# game/episode019.rpy:840
translate spanish ep019_paclerara_arrival_628fbb78:

#   "My route took me through a large part of the Residence."
    "Mi ruta me llevó por gran parte de la Residencia."

# game/episode019.rpy:841
translate spanish ep019_paclerara_arrival_4f96d838:

#   "Apart from the medical wing, there was a large residential section, and an area where most of the schools were housed."
    "Aparte del ala médica, había una gran sección residencial y una zona donde se alojaban la mayoría de las escuelas."

# game/episode019.rpy:842
translate spanish ep019_paclerara_arrival_204f2e48:

#   "Education seemed to be an important feature of the Paclerara Residence, housing anything from kindergarten to university level courses."
    "La educación parecía ser una característica importante de la Residencia Paclerara, que albergaba desde guarderías hasta cursos de nivel universitario."

# game/episode019.rpy:843
translate spanish ep019_paclerara_arrival_6631b57b:

#   "Our rooms were in a separate wing of the building, together with some restaurants and other hotel facilities."
    "Nuestras habitaciones estaban en un ala separada del edificio, junto con algunos restaurantes y otras instalaciones del hotel."

# game/episode019.rpy:845
translate spanish ep019_paclerara_arrival_18cd9dfe:

#   "My room was located fairly high up and fairly luxurious."
    "Mi habitación estaba situada bastante arriba y era bastante lujosa."

# game/episode019.rpy:846
translate spanish ep019_paclerara_arrival_d1f98f4f:

#   "A large balcony overlooked the lake below, and allowed for some breathtaking vistas of the forests stretching over the mountains in the distance."
    "Un gran balcón daba al lago y permitía disfrutar de unas impresionantes vistas de los bosques que se extendían por las montañas en la distancia."

# game/episode019.rpy:847
translate spanish ep019_paclerara_arrival_6f654ec2:

#   "First I freshened myself up in the ample bathroom before exploring the Residence for a bit."
    "Primero me refresqué en el amplio cuarto de baño antes de explorar un poco la Residencia."

# game/episode019.rpy:968
translate spanish ep019_paclerara_lilly_26a8d734_1:

#   l "You really must!"
    l "¡De verdad!"

# game/episode019.rpy:970
translate spanish ep019_paclerara_lilly_b7f4b180_1:

#   c "Noted."
    c "Tomo nota."

# game/episode019.rpy:973
translate spanish ep019_paclerara_lilly_bfd841ef_1:

#   "She became suddenly aware we were sitting on a bench in a rather public space, so her voice dropped to a whisper."
    "Se dio cuenta de repente de que estábamos sentados en un banco en un espacio bastante público, así que bajó la voz a un susurro."

# game/episode019.rpy:978
translate spanish ep019_paclerara_lilly_4b807efa_1:

#   l "Something you’ve done on more than one occasion."
    l "Algo que has hecho en más de una ocasión."

# game/episode019.rpy:979
translate spanish ep019_paclerara_lilly_9cf7bd03_1:

#   "That plain statement coupled with her longing expression made me gulp hard."
    "Esa simple afirmación unida a su expresión anhelante me hizo tragar saliva con fuerza."

# game/episode019.rpy:854
translate spanish ep019_paclerara_lilly_0dc511b7:

#   "Lilly sat in the courtyard of the residential building, enjoying the morning air."
    "Lilly se sentó en el patio del edificio residencial, disfrutando del aire matinal."

# game/episode019.rpy:856
translate spanish ep019_paclerara_lilly_7512efc3:

#   c "Hey, you're up early."
    c "Hey, te has levantado temprano."

# game/episode019.rpy:858
translate spanish ep019_paclerara_lilly_c3741e1f:

#   l "Didn't get much sleep last night."
    l "No dormí mucho anoche."

# game/episode019.rpy:859
translate spanish ep019_paclerara_lilly_7daa9f79:

#   l "So I figured I'd just get up, instead of keep on trying in frustration."
    l "Así que pensé en levantarme, en lugar de seguir intentándolo con frustración."

# game/episode019.rpy:860
translate spanish ep019_paclerara_lilly_f9746506:

#   c "Worried about Eva?"
    c "¿Preocupado por Eva?"

# game/episode019.rpy:861
translate spanish ep019_paclerara_lilly_cd87a2a4:

#   l "Yeah."
    l "Sí."

# game/episode019.rpy:863
translate spanish ep019_paclerara_lilly_73b8d77f:

#   l "It's so unfair, we have her back after what seemed like an eternity and now she's just slipped away again."
    l "Es tan injusto, la tenemos de vuelta después de lo que pareció una eternidad y ahora se nos ha vuelto a escapar."

# game/episode019.rpy:864
translate spanish ep019_paclerara_lilly_2adfcc54:

#   c "The doctors say she's likely to wake up soon."
    c "Los médicos dicen que es probable que despierte pronto."

# game/episode019.rpy:866
translate spanish ep019_paclerara_lilly_6570f58b:

#   l "But they don't know that for sure, do they?"
    l "Pero no lo saben con seguridad, ¿verdad?"

# game/episode019.rpy:867
translate spanish ep019_paclerara_lilly_5adcdc1d:

#   l "The estimation on the negative side is that it could also take weeks, or even months."
    l "La estimación en el lado negativo es que también podría llevar semanas, o incluso meses."

# game/episode019.rpy:868
