translate spanish ep018_eva_talk_f52ff7e4:

#   e "Okay, that sounds...{w} Eh...{w} Good."
    e "Vale, eso suena...{w} Eh...{w} Bien."

# game/episode018_conversations.rpy:134
translate spanish ep018_eva_talk_eb3d8cbc:

#   e "Sorry, but I’m just a little nervous."
    e "Lo siento, pero estoy un poco nervioso."

# game/episode018_conversations.rpy:135
translate spanish ep018_eva_talk_24366554:

#   c "I understand."
    c "Entiendo."

# game/episode018_conversations.rpy:136
translate spanish ep018_eva_talk_7fca092e:

#   c "It’s always tense, being intimate with someone for the first time."
    c "Siempre es tenso, intimar con alguien por primera vez."

# game/episode018_conversations.rpy:137
translate spanish ep018_eva_talk_207d9ee5:

#   c "Let me guide you and tell me if it hurts or if you want to stop."
    c "Déjame guiarte y dime si te duele o si quieres parar."

# game/episode018_conversations.rpy:138
translate spanish ep018_eva_talk_577e4bd1:

#   e "Okay."
    e "De acuerdo."

# game/episode018_conversations.rpy:150
translate spanish ep018_vess_talk_3f2e835e:

#   ve "You’re back."
    ve "Has vuelto."

