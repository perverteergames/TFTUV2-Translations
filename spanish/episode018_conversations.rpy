#   c "I am."
    c "Lo soy."

# game/episode018_conversations.rpy:153
translate spanish ep018_vess_talk_2cad867c:

#   ve "I was starting to get worried you’d abandoned me."
    ve "Empezaba a preocuparme que me hubieras abandonado."

