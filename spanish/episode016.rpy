    woman "A los escolguines no se les permiten visitas, así que la orden debe venir de arriba."

# game/episode016.rpy:250
translate spanish ep016_prison_871d0075:

#   c "The Council authorized it."
    c "El Consejo lo autorizó."

# game/episode016.rpy:251
