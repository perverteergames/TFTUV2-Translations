translate spanish ep021_vess_talk_f085868c:

#   ve "If it wasn’t for our relationship, I think I would have abandoned ship at one of the ports we visited in the past few weeks."
    ve "Si no fuera por nuestra relación, creo que habría abandonado el barco en alguno de los puertos que visitamos en las últimas semanas."

# game/episode021.rpy:1484
translate spanish ep021_vess_talk_2dea9bb3:

#   c "I’m happy to hear you didn’t bail on us, or rather, bail on me."
