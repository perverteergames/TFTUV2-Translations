    l "En absoluto, me alegro de que lo hayamos aclarado todo."

# game/episode017.rpy:1568
translate spanish ep017_lilly_1f641b25:

#   "She accepted my kiss gladly, and I instinctively knew she was at peace."
    "Aceptó mi beso con gusto e instintivamente supe que estaba en paz."

# game/episode017.rpy:1570
translate spanish ep017_lilly_a49aa0b4:

#   "The sound of the door opening interrupted our kiss."
    "El sonido de la puerta al abrirse interrumpió nuestro beso."

# game/episode017.rpy:1571
