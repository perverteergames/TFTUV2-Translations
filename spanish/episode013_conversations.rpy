#   ce "I really don't know what got into her, she's never yelled at me like that."
    ce "Realmente no sé qué le pasó, nunca me había gritado así."

# game/episode013_conversations.rpy:938
translate spanish ep013_celine_second_talk_4387e8d3:

#   c "I told Lilly everything about you and me."
    c "Le conté a Lilly todo sobre tú y yo."

# game/episode013_conversations.rpy:940
translate spanish ep013_celine_second_talk_3bdd7b97:

#   ce "Oh?"
    ce "¿Ah, sí?"

# game/episode013_conversations.rpy:941
translate spanish ep013_celine_second_talk_860fe87c:

#   ce "And because of that she's angry at me?"
    ce "¿Y por eso está enfadada conmigo?"

# game/episode013_conversations.rpy:942
translate spanish ep013_celine_second_talk_975f9871:

#   c "Jealousy."
    c "Celos."

# game/episode013_conversations.rpy:944
translate spanish ep013_celine_second_talk_635727e5:

#   ce "Jealousy, but she's your sister?"
    ce "¿Celos, pero es tu hermana?"

# game/episode013_conversations.rpy:945
translate spanish ep013_celine_second_talk_0a09d539:

#   c "She is."
    c "Lo es."

# game/episode013_conversations.rpy:947
translate spanish ep013_celine_second_talk_daa24cc8:

#   ce "Jealousy?"
    ce "¿Celos?"

# game/episode013_conversations.rpy:949
translate spanish ep013_celine_second_talk_12d2e699:

#   ce "So why is she jealous?"
    ce "Entonces, ¿por qué está celosa?"

# game/episode013_conversations.rpy:950
translate spanish ep013_celine_second_talk_c9fc2a0b:

#   ce "Does she think we aren't a good match?"
    ce "¿Cree que no somos una buena pareja?"

# game/episode013_conversations.rpy:951
translate spanish ep013_celine_second_talk_98b9b44f:

