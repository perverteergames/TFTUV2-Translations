translate spanish ep013_raene_second_talk_2d2d3861:

#   ra "Okay."
    ra "De acuerdo."

# game/episode013_conversations.rpy:839
translate spanish ep013_raene_second_talk_472ea363:

#   "I sat opposite of her on the bed and looked into her eyes, which wasn’t easy as her gaze shifted nervously."
    "Me senté frente a ella en la cama y la miré a los ojos, lo que no fue fácil porque su mirada se movía nerviosamente."

# game/episode013_conversations.rpy:840
translate spanish ep013_raene_second_talk_ad0f65c4:

#   c "Raene, I really like you."
    c "Raene, me gustas mucho."

# game/episode013_conversations.rpy:841
translate spanish ep013_raene_second_talk_01726e6e:

#   c "And you like me, don’t you?"
    c "Y yo te gusto, ¿verdad?"

# game/episode013_conversations.rpy:843
translate spanish ep013_raene_second_talk_be0230c1:

#   ra "Yes, I like you very much."
    ra "Sí, me gustas mucho."

# game/episode013_conversations.rpy:844
translate spanish ep013_raene_second_talk_8580cc2d:

#   c "It’s clear we both want each other."
    c "Está claro que ambos nos queremos."

# game/episode013_conversations.rpy:845
translate spanish ep013_raene_second_talk_97e7cc17:

#   c "But what happened earlier has made it clear you’re held back for some reason."
    c "Pero lo que ha pasado antes ha dejado claro que estás retenido por alguna razón."

# game/episode013_conversations.rpy:847
translate spanish ep013_raene_second_talk_395d0514:

#   ra "I...{w} That is...{w} Yes."
    ra "Yo...{w} Eso es...{w} Sí."

# game/episode013_conversations.rpy:849
translate spanish ep013_raene_second_talk_093d7eb5:

#   ra "For the longest time, people have expressed their discomfort with me, with who I want to be."
    ra "Durante mucho tiempo, la gente ha expresado su incomodidad conmigo, con lo que quiero ser."

# game/episode013_conversations.rpy:850
translate spanish ep013_raene_second_talk_4f2a582e:

#   ra "And now, when you and I are getting serious and ready to take the next step, I became conscious of that discomfort again."
    ra "Y ahora, cuando tú y yo nos ponemos serios y nos disponemos a dar el siguiente paso, vuelvo a ser consciente de esa incomodidad."

# game/episode013_conversations.rpy:851
translate spanish ep013_raene_second_talk_7ea068c1:

#   ra "Like I’m not allowed to feel the things I feel, if you know what I mean."
    ra "Como si no se me permitiera sentir las cosas que siento, si sabes a lo que me refiero."

# game/episode013_conversations.rpy:852
translate spanish ep013_raene_second_talk_3275e9ef:

#   c "I think so."
    c "Creo que sí."

# game/episode013_conversations.rpy:853
translate spanish ep013_raene_second_talk_4306aa6a:

#   c "The way your body reacts makes you too self-conscious?"
    c "¿Te cohíbe demasiado la forma en que reacciona tu cuerpo?"

# game/episode013_conversations.rpy:854
