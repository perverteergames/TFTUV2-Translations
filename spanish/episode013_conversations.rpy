translate spanish ep013_celine_talk_b1961263:

#   c "No, you don't."
    c "No, no tienes."

# game/episode013_conversations.rpy:902
translate spanish ep013_celine_talk_55079b6b:

#   c "I'm sorry, Céline."
    c "Lo siento, Céline."

# game/episode013_conversations.rpy:903
