translate spanish ep013_celine_talk_d45c39c5:

#   ce "Lead the way then."
    ce "Abre camino entonces."

# game/episode013_conversations.rpy:922
translate spanish ep013_celine_talk_adc1c75f:

#   "When we arrived at my quarters, all thoughts of having a drink were forgotten in an instant."
    "Cuando llegamos a mis aposentos, todos los pensamientos de tomar una copa se olvidaron en un instante."

# game/episode013_conversations.rpy:996
translate spanish ep013_celine_second_talk_bac99fde_1:

#   c "Right, if that's all you have to say, it might be better if I just leave you alone for a while."
    c "Bien, si eso es todo lo que tienes que decir, será mejor que te deje solo un rato."

# game/episode013_conversations.rpy:931
translate spanish ep013_celine_second_talk_a08e6bbf:

#   c "So, what happened on Douvis between you and Lilly?"
    c "Entonces, ¿qué pasó en Douvis entre tú y Lilly?"

# game/episode013_conversations.rpy:933
translate spanish ep013_celine_second_talk_b461db25:

#   ce "We were carrying a crate of supplies back to the ship."
    ce "Llevábamos una caja de suministros de vuelta al barco."

# game/episode013_conversations.rpy:934
translate spanish ep013_celine_second_talk_215a2430:

#   ce "Lilly didn't seem to care about my pace and I couldn't keep up with her."
    ce "A Lilly no parecía importarle mi ritmo y yo no podía seguirla."

# game/episode013_conversations.rpy:935
translate spanish ep013_celine_second_talk_2213ab70:

#   ce "So the crate slipped out of my hand and fell to the floor."
    ce "Así que la caja se me resbaló de la mano y cayó al suelo."

# game/episode013_conversations.rpy:936
translate spanish ep013_celine_second_talk_b41917a3:

#   ce "That's when she started yelling and insulting me."
    ce "Fue entonces cuando empezó a gritarme y a insultarme."

# game/episode013_conversations.rpy:937
