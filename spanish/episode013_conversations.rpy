    ce "Soy el único que puede hacerte feliz."

# game/episode013_conversations.rpy:908
translate spanish ep013_celine_talk_4efe6d8b:

#   ce "Come back, please!"
    ce "¡Vuelve, por favor!"

# game/episode013_conversations.rpy:910
translate spanish ep013_celine_talk_cac034fc:

#   "I hurried through the corridors of the ship, away from her increasingly desperate pleas."
    "Me apresuré por los pasillos de la nave, lejos de sus súplicas cada vez más desesperadas."

# game/episode013_conversations.rpy:914
translate spanish ep013_celine_talk_c0e2ed51:

#   c "Do you fancy a night cap in my quarters?"
    c "¿Te apetece una copa en mis aposentos?"

