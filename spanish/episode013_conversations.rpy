    ce "Me encantaría."

# game/episode013_conversations.rpy:918
translate spanish ep013_celine_talk_49924f8b:

#   ce "Also, I have a surprise for you."
    ce "Además, tengo una sorpresa para ti."

# game/episode013_conversations.rpy:919
translate spanish ep013_celine_talk_9f6ba1db:

#   c "Just know that I can't wait to unwrap you."
    c "Que sepas que estoy deseando desenvolverte."

